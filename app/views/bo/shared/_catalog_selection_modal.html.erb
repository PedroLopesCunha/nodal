<div class="modal fade" id="catalogSelectionModal" tabindex="-1" aria-labelledby="catalogSelectionModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="catalogSelectionModalLabel">
          <i class="fa-solid fa-list-check me-2"></i><%= t('bo.catalog.selection.title') %>
        </h5>
        <button type="button" class="btn-close" data-action="click->catalog#doneSelecting"></button>
      </div>

      <div class="modal-body">
        <turbo-frame id="catalog_selection"
                     data-catalog-target="selectionFrame"
                     data-src="<%= catalog_selection_bo_products_path(params[:org_slug]) %>">
          <div class="text-center py-4">
            <div class="spinner-border spinner-border-sm text-muted" role="status"></div>
            <p class="text-muted small mt-2"><%= t('bo.common.loading', default: 'Loading...') %></p>
          </div>
        </turbo-frame>
      </div>

      <div class="modal-footer d-flex justify-content-between">
        <div class="text-muted small">
          <i class="fa-solid fa-box me-1"></i>
          <strong data-catalog-target="productCount">0</strong> <%= t('bo.catalog.products_selected') %>
          &middot;
          <i class="fa-solid fa-folder me-1"></i>
          <strong data-catalog-target="categoryCount">0</strong> <%= t('bo.catalog.categories_selected') %>
        </div>
        <button type="button" class="btn btn-primary" data-action="click->catalog#doneSelecting">
          <i class="fa-solid fa-check me-1"></i> <%= t('bo.catalog.selection.done') %>
        </button>
      </div>
    </div>
  </div>
</div>
