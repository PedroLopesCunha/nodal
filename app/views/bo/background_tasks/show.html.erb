<% content_for :bo_main_content do %>

<div data-controller="task-progress"
     data-task-progress-url-value="<%= bo_background_task_path(params[:org_slug], @task, format: :json) %>"
     data-task-progress-redirect-value="<%= bo_products_path(params[:org_slug]) %>">

<div class="bo-page-header">
  <div class="d-flex align-items-center gap-3">
    <div class="rounded bg-primary d-flex align-items-center justify-content-center text-white" style="width: 60px; height: 60px;">
      <i class="fa-solid fa-gear fa-spin fa-lg" data-task-progress-target="icon"></i>
    </div>
    <div>
      <h1 data-task-progress-target="title"><%= t("bo.background_tasks.#{@task.task_type}.title", default: t('bo.background_tasks.processing')) %></h1>
      <span class="text-muted" data-task-progress-target="subtitle"><%= t('bo.background_tasks.please_wait') %></span>
    </div>
  </div>
</div>

<div class="bo-page-body">

  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card">
        <div class="card-body p-4">

          <!-- Progress bar -->
          <div data-task-progress-target="progressSection">
            <div class="d-flex justify-content-between mb-2">
              <span class="text-muted" data-task-progress-target="statusText"><%= t('bo.background_tasks.starting') %></span>
              <span class="fw-semibold" data-task-progress-target="percentText">0%</span>
            </div>
            <div class="progress" style="height: 24px;">
              <div class="progress-bar progress-bar-striped progress-bar-animated"
                   role="progressbar"
                   style="width: 0%"
                   data-task-progress-target="progressBar">
              </div>
            </div>
          </div>

          <!-- Result (hidden until done) -->
          <div class="d-none" data-task-progress-target="resultSection">
          </div>

        </div>
      </div>
    </div>
  </div>

</div>

</div>

<% end %>
