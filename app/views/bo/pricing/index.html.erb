<% content_for :bo_main_content do %>

<div data-controller="email-notification">

<!-- Sticky Header -->
<div class="bo-page-header">
  <div class="d-flex justify-content-between align-items-start">
    <div>
      <h1><%= t('bo.pricing.index.title') %></h1>
      <p class="text-muted mb-0"><%= t('bo.pricing.index.subtitle') %></p>
    </div>
    <div class="bo-page-actions">
      <% case @tab %>
      <% when 'product_discounts' %>
        <%= link_to new_bo_product_discount_path(params[:org_slug]), class: "btn btn-primary" do %>
          <i class="fa-solid fa-plus me-1"></i> <%= t('bo.pricing.add_discount') %>
        <% end %>
      <% when 'client_tiers' %>
        <%= link_to new_bo_customer_discount_path(params[:org_slug]), class: "btn btn-primary" do %>
          <i class="fa-solid fa-plus me-1"></i> <%= t('bo.pricing.add_discount') %>
        <% end %>
      <% when 'custom_pricing' %>
        <%= link_to new_bo_customer_product_discount_path(params[:org_slug]), class: "btn btn-primary" do %>
          <i class="fa-solid fa-plus me-1"></i> <%= t('bo.pricing.add_discount') %>
        <% end %>
      <% when 'order_tiers' %>
        <%= link_to new_bo_order_discount_path(params[:org_slug]), class: "btn btn-primary" do %>
          <i class="fa-solid fa-plus me-1"></i> <%= t('bo.pricing.add_discount') %>
        <% end %>
      <% when 'promo_codes' %>
        <%= link_to new_bo_promo_code_path(params[:org_slug]), class: "btn btn-primary" do %>
          <i class="fa-solid fa-plus me-1"></i> <%= t('bo.pricing.promo_codes.add') %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<!-- Page Body -->
<div class="bo-page-body">
  <!-- Tab Navigation -->
  <div class="card mb-4">
    <div class="card-body p-0">
      <ul class="nav nav-pills nav-fill border-bottom" role="tablist">
        <li class="nav-item" role="presentation">
          <%= link_to bo_pricing_path(params[:org_slug], tab: 'product_discounts'),
              class: "nav-link rounded-0 py-3 #{'active' if @tab == 'product_discounts'}" do %>
            <i class="fa-solid fa-tag me-2"></i><%= t('bo.pricing.tabs.product_discounts') %>
          <% end %>
        </li>
        <li class="nav-item" role="presentation">
          <%= link_to bo_pricing_path(params[:org_slug], tab: 'client_tiers'),
              class: "nav-link rounded-0 py-3 #{'active' if @tab == 'client_tiers'}" do %>
            <i class="fa-solid fa-users me-2"></i><%= t('bo.pricing.tabs.client_tiers') %>
          <% end %>
        </li>
        <li class="nav-item" role="presentation">
          <%= link_to bo_pricing_path(params[:org_slug], tab: 'custom_pricing'),
              class: "nav-link rounded-0 py-3 #{'active' if @tab == 'custom_pricing'}" do %>
            <i class="fa-solid fa-dollar-sign me-2"></i><%= t('bo.pricing.tabs.custom_pricing') %>
          <% end %>
        </li>
        <li class="nav-item" role="presentation">
          <%= link_to bo_pricing_path(params[:org_slug], tab: 'order_tiers'),
              class: "nav-link rounded-0 py-3 #{'active' if @tab == 'order_tiers'}" do %>
            <i class="fa-solid fa-cart-shopping me-2"></i><%= t('bo.pricing.tabs.order_tiers') %>
          <% end %>
        </li>
        <li class="nav-item" role="presentation">
          <%= link_to bo_pricing_path(params[:org_slug], tab: 'promo_codes'),
              class: "nav-link rounded-0 py-3 #{'active' if @tab == 'promo_codes'}" do %>
            <i class="fa-solid fa-ticket me-2"></i><%= t('bo.pricing.tabs.promo_codes') %>
          <% end %>
        </li>
      </ul>
    </div>
  </div>

  <!-- Tab Content -->
  <% case @tab %>
  <% when 'product_discounts' %>
    <%= render 'product_discounts' %>
  <% when 'client_tiers' %>
    <%= render 'client_tiers' %>
  <% when 'custom_pricing' %>
    <%= render 'custom_pricing' %>
  <% when 'order_tiers' %>
    <%= render 'order_tiers' %>
  <% when 'promo_codes' %>
    <%= render 'promo_codes' %>
  <% end %>
</div>

<%= render 'bo/shared/email_notification_modal' %>

<% if @pending_notification %>
<script>
  (function() {
    function openModal() {
      var modalEl = document.getElementById('emailNotificationModal');
      if (!modalEl) return;
      var form = document.getElementById('emailNotificationForm');
      var countEl = document.getElementById('emailNotificationCount');
      var typeEl = document.getElementById('emailNotificationType');

      form.action = '<%= send_email_bo_discount_email_notification_path(params[:org_slug], @pending_notification) %>';
      countEl.textContent = '<%= @pending_notification.recipient_count %>';
      typeEl.textContent = '<%= @pending_notification.notifiable_type.underscore.humanize %>';

      var recipientsEl = document.getElementById('emailNotificationRecipients');
      recipientsEl.innerHTML = '<div class="text-center py-2"><div class="spinner-border spinner-border-sm text-muted" role="status"></div></div>';

      var modal = new bootstrap.Modal(modalEl);
      modal.show();

      fetch('<%= recipients_bo_discount_email_notification_path(params[:org_slug], @pending_notification) %>', { headers: { 'Accept': 'text/html' } })
        .then(function(r) { return r.text(); })
        .then(function(html) { recipientsEl.innerHTML = html; })
        .catch(function() { recipientsEl.innerHTML = ''; });
    }

    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      setTimeout(openModal, 100);
    } else {
      document.addEventListener('DOMContentLoaded', openModal);
    }
  })();
</script>
<% end %>

</div>

<% end %>
