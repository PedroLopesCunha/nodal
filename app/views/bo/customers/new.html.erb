<% content_for :bo_main_content do %>

<div class="bo-page-header">
  <div class="d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center gap-3">
      <%= link_to bo_customers_path(params[:org_slug]), class: "text-muted text-decoration-none" do %>
        <i class="fa-solid fa-arrow-left fa-lg"></i>
      <% end %>

      <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white fw-bold" style="width: 60px; height: 60px; font-size: 1.25rem;">
        <i class="fa-solid fa-user-plus"></i>
      </div>

      <div>
        <h1><%= t('bo.customers.new.title') %></h1>
        <span class="text-muted"><%= t('bo.customers.new.subtitle') %></span>
      </div>
    </div>

    <div class="bo-page-actions">
      <%= link_to bo_customers_path(params[:org_slug]), class: "btn btn-outline-secondary" do %>
        <%= t('bo.common.actions.cancel') %>
      <% end %>
      <button type="submit" form="customer-form" class="btn btn-primary">
        <i class="fa-solid fa-check"></i> <%= t('bo.customers.new.create_customer') %>
      </button>
    </div>
  </div>
</div>

<div class="bo-page-body">

<%= form_with model: @customer, url: bo_customers_path(params[:org_slug]), method: :post, id: "customer-form" do |f| %>
  <div class="row g-3">
    <div class="col-md-8">
      <div class="card mb-3">
        <div class="card-body">
          <h5 class="card-title mb-4"><%= t('bo.customers.form.contact_information') %></h5>

          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label"><%= t('bo.customers.form.contact_name') %> <span class="text-danger">*</span></label>
              <%= f.text_field :contact_name, class: "form-control", placeholder: t('bo.customers.form.contact_name_placeholder'), required: true %>
            </div>
            <div class="col-md-6">
              <label class="form-label"><%= t('bo.customers.form.email') %> <span class="text-danger">*</span></label>
              <%= f.email_field :email, class: "form-control", placeholder: t('bo.customers.form.email_placeholder'), required: true %>
            </div>
          </div>

          <div class="row g-3 mt-1">
            <div class="col-md-6">
              <label class="form-label"><%= t('bo.customers.form.phone') %></label>
              <%= f.text_field :contact_phone, class: "form-control", placeholder: t('bo.customers.form.phone_placeholder') %>
            </div>
          </div>
        </div>
      </div>

      <div class="card mb-3">
        <div class="card-body">
          <h5 class="card-title mb-4"><%= t('bo.customers.form.company_details') %></h5>

          <div class="row g-3">
            <div class="col-md-12">
              <label class="form-label"><%= t('bo.customers.form.company_name') %> <span class="text-danger">*</span></label>
              <%= f.text_field :company_name, class: "form-control", placeholder: t('bo.customers.form.company_name_placeholder'), required: true %>
            </div>
          </div>

          <div class="row g-3 mt-1">
            <div class="col-md-12">
              <label class="form-label"><%= t('bo.customers.form.taxpayer_id') %></label>
              <%= f.text_field :taxpayer_id, class: "form-control", placeholder: t('bo.customers.form.taxpayer_id_placeholder') %>
              <small class="text-muted"><%= t('bo.customers.form.taxpayer_id_hint') %></small>
            </div>

            <hr class="my-4">

            <h6 class="mb-3"><%= t('bo.customers.form.billing_address') %></h6>

            <%= f.fields_for :billing_address_with_archived do |ba| %>
              <%= ba.hidden_field :address_type, value: "billing" %>

              <div class="row g-3">
                <div class="col-md-8">
                  <label class="form-label"><%= t('bo.customers.form.address.street') %></label>
                  <%= ba.text_field :street_name, class: "form-control" %>
                </div>

                <div class="col-md-4">
                  <label class="form-label"><%= t('bo.customers.form.address.number') %></label>
                  <%= ba.text_field :street_nr, class: "form-control" %>
                </div>

                <div class="col-md-4">
                  <label class="form-label"><%= t('bo.customers.form.address.postal_code') %></label>
                  <%= ba.text_field :postal_code, class: "form-control" %>
                </div>

                <div class="col-md-4">
                  <label class="form-label"><%= t('bo.customers.form.address.city') %></label>
                  <%= ba.text_field :city, class: "form-control" %>
                </div>

                <div class="col-md-4">
                  <label class="form-label"><%= t('bo.customers.form.address.country') %></label>
                  <%= ba.text_field :country, class: "form-control" %>
                </div>
              </div>
            <% end %>

            <hr class="my-4">

            <h6 class="mb-3"><%= t('bo.customers.form.shipping_addresses') %></h6>

            <div data-controller="nested-addresses">
              <div data-nested-addresses-target="container">
                <%= f.fields_for :shipping_addresses_with_archived do |sa| %>
                  <%= render "shipping_address_fields", f: sa %>
                <% end %>
              </div>

              <template data-nested-addresses-target="template">
                <%= f.fields_for(
                  :shipping_addresses_with_archived,
                  Address.new(address_type: "shipping", active: true),
                  child_index: "NEW_RECORD"
                ) do |sa| %>
                  <%= render "shipping_address_fields", f: sa %>
                <% end %>
              </template>

              <button
                type="button"
                class="btn btn-sm btn-outline-primary mt-2"
                data-action="nested-addresses#add"
              >
                <i class="fa-solid fa-plus"></i> <%= t('bo.customers.form.add_shipping_address') %>
              </button>
            </div>
          </div>
        </div>
      </div>

    </div>

    <div class="col-md-4">
      <div class="card mb-3">
        <div class="card-body">
          <h5 class="card-title mb-4"><%= t('bo.customers.form.account_status') %></h5>

          <div class="form-check form-switch">
            <%= f.check_box :active, class: "form-check-input", role: "switch", id: "activeSwitch", checked: true %>
            <label class="form-check-label" for="activeSwitch"><%= t('bo.customers.form.active_customer') %></label>
          </div>
          <small class="text-muted"><%= t('bo.customers.form.inactive_hint') %></small>
        </div>
      </div>

      <div class="card">
        <div class="card-body">
          <h5 class="card-title mb-4"><%= t('bo.customers.form.category') %></h5>
          <%= f.select :customer_category_id,
              options_from_collection_for_select(@customer_categories, :id, :name),
              { include_blank: t('bo.customers.form.no_category') },
              class: "form-select" %>
        </div>
      </div>
    </div>
  </div>
<% end %>

</div>

<% end %>
