<% content_for :bo_main_content do%>

<div class="bo-page-header">
  <div class="d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center gap-3">
      <%= link_to bo_customer_path(params[:org_slug], @customer, filter_params_hash), class: "text-muted text-decoration-none" do %>
        <i class="fa-solid fa-arrow-left fa-lg"></i>
      <% end %>

      <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold" style="width: 60px; height: 60px; font-size: 1.25rem;">
        <%= @customer.contact_name&.split&.map(&:first)&.join&.upcase || "?" %>
      </div>

      <div>
        <h1>Editar empresa: <%= @customer.company_name %></h1>
        <p class="text-muted small">Edita dados fiscais e de contacto da empresa. Para gerir as pessoas/logins, volta à página do cliente.</p>
      </div>
    </div>

    <div class="bo-page-actions">
      <%= link_to bo_customer_path(params[:org_slug], @customer, filter_params_hash), class: "btn btn-outline-secondary" do %>
        <%= t('bo.common.actions.cancel') %>
      <% end %>
      <button type="submit" form="customer-form" class="btn btn-primary">
        <i class="fa-solid fa-check"></i> <%= t('bo.common.actions.save_changes') %>
      </button>
    </div>
  </div>
</div>

<div class="bo-page-body">
<%= form_with model: @customer, url: bo_customer_path(params[:org_slug], @customer, filter_params_hash), method: :patch, id: "customer-form" do |f| %>
  <div class="row g-3">
    <div class="col-md-8">
      <div class="card mb-3">
        <div class="card-body">
          <% if pure_sales_rep? %>
            <h5 class="card-title mb-1">Empresa</h5>
            <p class="text-muted small mb-4">Dados fiscais e de contacto desta empresa.</p>
          <% else %>
            <h5 class="card-title mb-4"><%= t('bo.customers.form.contact_information') %></h5>
          <% end %>

          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label"><%= t('bo.customers.form.contact_name') %></label>
              <%= f.text_field :contact_name, class: "form-control", placeholder: t('bo.customers.form.contact_name_placeholder') %>
            </div>
            <div class="col-md-6">
              <label class="form-label"><%= pure_sales_rep? ? "Email da empresa" : t('bo.customers.form.email') %></label>
              <%= f.email_field :email, class: "form-control", placeholder: t('bo.customers.form.email_placeholder') %>
            </div>
          </div>

          <div class="row g-3 mt-1">
            <div class="col-md-6">
              <label class="form-label"><%= pure_sales_rep? ? "Telefone da empresa" : t('bo.customers.form.phone') %></label>
              <%= f.text_field :contact_phone, class: "form-control", placeholder: t('bo.customers.form.phone_placeholder') %>
            </div>
          </div>

          <% if pure_sales_rep? %>
            <hr class="my-4">

            <%# Read-only fiscal/billing data — admin-only to change.
                Rendered as plain text (no inputs) to avoid suggesting editability. %>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label mb-1">NIF</label>
                <div class="text-muted small py-1">
                  <i class="fa-solid fa-building me-1"></i> <%= @customer.taxpayer_id.presence || "—" %>
                </div>
              </div>
              <div class="col-md-6">
                <label class="form-label mb-1">Morada de Faturação</label>
                <div class="text-muted small py-1">
                  <i class="fa-solid fa-location-dot me-1"></i> <%= @customer.billing_address&.full_address || "—" %>
                </div>
              </div>
            </div>

            <hr class="my-4">

            <%# Shipping addresses — existing are read-only, new ones can be added %>
            <h6 class="mb-3">Moradas de Envio</h6>
            <% if @customer.shipping_addresses.any? %>
              <ul class="list-unstyled small mb-3">
                <% @customer.shipping_addresses.each do |addr| %>
                  <li class="text-muted py-1">
                    <i class="fa-solid fa-truck me-1"></i> <%= addr.full_address %>
                  </li>
                <% end %>
              </ul>
            <% end %>

            <div data-controller="nested-addresses">
              <div data-nested-addresses-target="container">
                <%# Only renders NEW shipping address inputs (no fields_for over existing,
                    so the existing records aren't touched on submit). %>
              </div>

              <template data-nested-addresses-target="template">
                <%= f.fields_for(
                  :shipping_addresses_with_archived,
                  Address.new(address_type: "shipping", active: true),
                  child_index: "NEW_RECORD"
                ) do |sa| %>
                  <%= render "shipping_address_fields", f: sa %>
                <% end %>
              </template>

              <button type="button" class="btn btn-sm btn-outline-primary mt-2" data-action="nested-addresses#add">
                <i class="fa-solid fa-plus"></i> Adicionar morada de envio
              </button>
            </div>
          <% end %>
        </div>
      </div>

      <% unless pure_sales_rep? %>
      <div class="card">
        <div class="card-body">
          <h5 class="card-title mb-4"><%= t('bo.customers.form.company_details') %></h5>

          <div class="row g-3">
            <div class="col-md-12">
              <label class="form-label"><%= t('bo.customers.form.company_name') %></label>
              <%= f.text_field :company_name, class: "form-control", placeholder: t('bo.customers.form.company_name_placeholder') %>
            </div>
          </div>

          <div class="row g-3 mt-1">
            <div class="col-md-12">
              <label class="form-label"><%= t('bo.customers.form.taxpayer_id') %></label>
              <%= f.text_field :taxpayer_id, class: "form-control", placeholder: t('bo.customers.form.taxpayer_id_placeholder') %>
              <small class="text-muted"><%= t('bo.customers.form.taxpayer_id_hint') %></small>
            </div>

            <hr class="my-4">

              <h6 class="mb-3"><%= t('bo.customers.form.billing_address') %></h6>

              <%= f.fields_for :billing_address_with_archived do |ba| %>
                <%= ba.hidden_field :address_type, value: "billing" %>

                <div class="row g-3">
                  <div class="col-md-8">
                    <label class="form-label"><%= t('bo.customers.form.address.street') %></label>
                    <%= ba.text_field :street_name, class: "form-control" %>
                  </div>

                  <div class="col-md-4">
                    <label class="form-label"><%= t('bo.customers.form.address.number') %></label>
                    <%= ba.text_field :street_nr, class: "form-control" %>
                  </div>

                  <div class="col-md-4">
                    <label class="form-label"><%= t('bo.customers.form.address.postal_code') %></label>
                    <%= ba.text_field :postal_code, class: "form-control" %>
                  </div>

                  <div class="col-md-4">
                    <label class="form-label"><%= t('bo.customers.form.address.city') %></label>
                    <%= ba.text_field :city, class: "form-control" %>
                  </div>

                  <div class="col-md-4">
                    <label class="form-label"><%= t('bo.customers.form.address.country') %></label>
                    <%= ba.text_field :country, class: "form-control" %>
                  </div>
                </div>
              <% end %>

            <hr class="my-4">

                <h6 class="mb-3"><%= t('bo.customers.form.shipping_addresses') %></h6>

                  <div data-controller="nested-addresses">
                    <div data-nested-addresses-target="container">
                      <%= f.fields_for :shipping_addresses_with_archived do |sa| %>
                        <%= render "shipping_address_fields", f: sa %>
                      <% end %>
                    </div>

                    <template data-nested-addresses-target="template">
                      <%= f.fields_for(
                        :shipping_addresses_with_archived,
                        Address.new(address_type: "shipping", active: true), 
                        child_index: "NEW_RECORD"
                      ) do |sa| %>
                        <%= render "shipping_address_fields", f: sa %>
                      <% end %>
                    </template>

                    <button
                      type="button"
                      class="btn btn-sm btn-outline-primary mt-2"
                      data-action="nested-addresses#add"
                    >
                      <i class="fa-solid fa-plus"></i> <%= t('bo.customers.form.add_shipping_address') %>
                    </button>
                  </div>
          </div>
        </div>
      </div>
      <% end %>
    </div>

    <div class="col-md-4">
      <% unless pure_sales_rep? %>
      <div class="card mb-3">
        <div class="card-body">
          <h5 class="card-title mb-4"><%= t('bo.customers.form.account_status') %></h5>

          <div class="form-check form-switch">
            <%= f.check_box :active, class: "form-check-input", role: "switch", id: "activeSwitch" %>
            <label class="form-check-label" for="activeSwitch"><%= t('bo.customers.form.active_customer') %></label>
          </div>
          <small class="text-muted"><%= t('bo.customers.form.inactive_hint') %></small>

          <hr class="my-3">

          <div class="form-check form-switch">
            <%= f.check_box :email_notifications_enabled, class: "form-check-input", role: "switch", id: "emailNotificationsSwitch" %>
            <label class="form-check-label" for="emailNotificationsSwitch"><%= t('bo.customers.form.email_notifications') %></label>
          </div>
          <small class="text-muted"><%= t('bo.customers.form.email_notifications_hint') %></small>
        </div>
      </div>

      <div class="card mb-3">
        <div class="card-body">
          <h5 class="card-title mb-4"><%= t('bo.customers.form.category') %></h5>
          <%= f.select :customer_category_id,
              options_from_collection_for_select(@customer_categories, :id, :name, @customer.customer_category_id),
              { include_blank: t('bo.customers.form.no_category') },
              class: "form-select" %>
        </div>
      </div>

      <div class="card">
        <div class="card-body">
          <h5 class="card-title mb-4"><%= t('bo.customers.form.account_info') %></h5>

          <div class="border-bottom pb-3 mb-3">
            <small class="text-muted d-block"><%= t('bo.customers.show.member_since') %></small>
            <span><%= @customer.created_at.strftime("%-m/%-d/%Y") %></span>
          </div>

          <div>
            <small class="text-muted d-block"><%= t('bo.customers.form.last_updated') %></small>
            <span><%= @customer.updated_at.strftime("%-m/%-d/%Y") %></span>
          </div>
        </div>
      </div>
      <% else %>
      <div class="card border-info">
        <div class="card-body">
          <h5 class="card-title mb-3"><i class="fa-solid fa-info-circle text-info me-2"></i>Edição limitada</h5>
          <p class="small text-muted mb-0">
            Como vendedor, podes atualizar dados de contacto (nome, email, telefone) mas não a empresa, NIF ou moradas — essas alterações requerem um admin.
          </p>
        </div>
      </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# Separate form (outside the main customer form) for vendedor atribuído.
    Only admins/owners can change it — pure reps don't see this card. %>
<% if current_org_member&.role&.in?(%w[owner admin]) %>
  <div class="row g-3 mt-3">
    <div class="col-md-8 offset-md-0">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title mb-3"><i class="fa-solid fa-user-tie me-2"></i>Vendedor atribuído</h5>
          <%= form_with url: bo_customer_customer_assignment_path(org_slug: current_organisation.slug, customer_id: @customer.id), method: :post, local: true, class: "d-flex gap-2 align-items-center flex-wrap" do %>
            <% rep_options = current_organisation.org_members.where(is_sales_rep: true).joins(:member).includes(:member).map { |om| [om.display_name, om.id] } %>
            <%= select_tag :org_member_id,
                  options_for_select([["Nenhum (sem vendedor)", nil]] + rep_options, @customer.sales_rep&.id),
                  class: "form-select",
                  style: "max-width: 360px;" %>
            <button type="submit" class="btn btn-primary">
              <i class="fa-solid fa-check me-1"></i> Atualizar vendedor
            </button>
            <% if @customer.sales_rep %>
              <small class="text-muted ms-2">
                Atual: <strong><%= @customer.sales_rep.display_name %></strong>
                <% if (assigned = @customer.customer_assignment&.assigned_at) %>
                  (desde <%= l(assigned.to_date, format: :short) %>)
                <% end %>
              </small>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
</div>

<% end %>
