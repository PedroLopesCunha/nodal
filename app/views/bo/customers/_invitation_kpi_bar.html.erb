<%# locals: kpis (Hash with 4 invitation counts), org_slug, current_status (params[:status]) %>
<%
  tiles = [
    { key: :active_users,        icon: "fa-circle-check",        accent: "success",   status: "active" },
    { key: :pending_users,       icon: "fa-hourglass-half",      accent: "info",      status: "pending" },
    { key: :stale_pending_users, icon: "fa-triangle-exclamation", accent: "warning",  status: "stale_pending" },
    { key: :uninvited_users,     icon: "fa-envelope-open",       accent: "secondary", status: "not_invited" }
  ]
%>
<div class="row g-3 mb-3">
  <% tiles.each do |tile| %>
    <div class="col-md-3 col-sm-6">
      <% active = (current_status == tile[:status]) %>
      <%= link_to bo_customers_path(org_slug: org_slug, status: tile[:status]),
                  class: "card text-decoration-none text-body border-0 shadow-sm h-100 customer-health-tile #{'border-primary' if active}",
                  style: ("border: 2px solid var(--bs-primary) !important;" if active) do %>
        <div class="card-body py-3">
          <div class="d-flex align-items-center gap-3">
            <div class="rounded-circle bg-<%= tile[:accent] %>-subtle text-<%= tile[:accent] %> d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px;">
              <i class="fa-solid <%= tile[:icon] %>"></i>
            </div>
            <div class="min-width-0">
              <div class="text-muted small d-flex align-items-center gap-1">
                <%= t("bo.dashboards.customer_health.#{tile[:key]}") %>
                <i class="fa-regular fa-circle-question text-muted" style="font-size: 0.7rem;"
                   title="<%= t("bo.dashboards.customer_health.#{tile[:key]}_hint") %>"></i>
              </div>
              <div class="fs-5 fw-bold"><%= kpis[tile[:key]] %></div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
