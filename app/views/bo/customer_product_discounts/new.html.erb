<% content_for :bo_main_content do %>

<div class="bo-page-header">
  <div class="d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center gap-3">
      <%= link_to bo_pricing_path(params[:org_slug], tab: 'custom_pricing'), class: "text-muted text-decoration-none" do %>
        <i class="fa-solid fa-arrow-left fa-lg"></i>
      <% end %>

      <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white fw-bold" style="width: 60px; height: 60px; font-size: 1.25rem;">
        <i class="fa-solid fa-dollar-sign"></i>
      </div>

      <div>
        <h1><%= t('bo.pricing.custom_pricing.new.title') %></h1>
        <span class="text-muted"><%= t('bo.pricing.custom_pricing.new.subtitle') %></span>
      </div>
    </div>

    <div class="bo-page-actions">
      <%= link_to bo_pricing_path(params[:org_slug], tab: 'custom_pricing'), class: "btn btn-outline-secondary" do %>
        <%= t('bo.common.actions.cancel') %>
      <% end %>
      <button type="submit" form="customer-product-discount-form" class="btn btn-primary">
        <i class="fa-solid fa-check"></i> <%= t('bo.pricing.custom_pricing.new.submit') %>
      </button>
    </div>
  </div>
</div>

<div class="bo-page-body">

<% if @discount.errors.any? %>
  <div class="alert alert-danger mb-4">
    <h6 class="alert-heading"><%= t('bo.pricing.errors.title') %></h6>
    <ul class="mb-0">
      <% @discount.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @discount, url: bo_customer_product_discounts_path(params[:org_slug]), method: :post, id: "customer-product-discount-form" do |f| %>
  <div class="row g-3">
    <div class="col-md-8">
      <div class="card mb-3">
        <div class="card-body">
          <h5 class="card-title mb-4"><%= t('bo.pricing.custom_pricing.card_title') %></h5>

          <div class="row g-3" data-controller="discount-target variant-overrides"
               data-variant-overrides-url-value="<%= variant_overrides_bo_customer_product_discounts_path(params[:org_slug]) %>"
               data-discount-target-url-value="<%= variant_overrides_bo_customer_product_discounts_path(params[:org_slug]) %>">
            <div class="col-md-12 mb-2">
              <label class="form-label"><%= t('bo.pricing.form.client') %> <span class="text-danger">*</span></label>
              <select name="customer_product_discount[customer_id]" id="customer_product_discount_customer_id" class="form-select" required
                      data-controller="tom-select">
                <option value=""><%= t('bo.pricing.form.select_client') %></option>
                <% @customers.each do |customer| %>
                  <option value="<%= customer.id %>" data-sku="<%= customer.email %>" <%= 'selected' if @discount.customer_id == customer.id %>><%= customer.company_name %></option>
                <% end %>
              </select>
            </div>

            <div class="col-md-12 mb-2">
              <label class="form-label"><%= t('bo.pricing.product_discounts.target_type') %></label>
              <div class="d-flex gap-3">
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="target_type" id="target_product" value="product"
                         data-action="change->discount-target#toggle"
                         <%= 'checked' unless @discount.category? %>>
                  <label class="form-check-label" for="target_product"><%= t('bo.pricing.product_discounts.product_target') %></label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="target_type" id="target_category" value="category"
                         data-action="change->discount-target#toggle"
                         <%= 'checked' if @discount.category? %>>
                  <label class="form-check-label" for="target_category"><%= t('bo.pricing.product_discounts.category_target') %></label>
                </div>
              </div>
            </div>

            <div class="col-md-12" data-discount-target-target="productWrapper">
              <label class="form-label"><%= t('bo.pricing.form.product') %> <span class="text-danger">*</span></label>
              <select name="customer_product_discount[product_id]" id="customer_product_discount_product_id" class="form-select"
                      data-controller="tom-select"
                      data-discount-target-target="productSelect"
                      data-action="change->variant-overrides#change">
                <option value=""><%= t('bo.pricing.form.select_product') %></option>
                <% @products.each do |product| %>
                  <option value="<%= product.id %>" data-sku="<%= product.sku %>" <%= 'selected' if @discount.product_id == product.id %>><%= product.name %></option>
                <% end %>
              </select>
            </div>

            <div class="col-md-12 d-none" data-discount-target-target="categoryWrapper">
              <label class="form-label"><%= t('bo.pricing.product_discounts.category_target') %> <span class="text-danger">*</span></label>
              <select name="customer_product_discount[category_id]" id="customer_product_discount_category_id" class="form-select"
                      data-controller="tom-select"
                      data-discount-target-target="categorySelect"
                      data-action="change->discount-target#categoryChanged">
                <option value=""><%= t('bo.pricing.product_discounts.select_category') %></option>
                <% @categories_for_select.each do |name, id| %>
                  <option value="<%= id %>" <%= 'selected' if @discount.category_id == id %>><%= name %></option>
                <% end %>
              </select>
            </div>
          </div>

          <div class="row g-3 mt-1">
            <div class="col-md-4">
              <label class="form-label"><%= t('bo.pricing.form.discount_type') %> <span class="text-danger">*</span></label>
              <%= f.select :discount_type, [[t('bo.pricing.form.percentage'), 'percentage'], [t('bo.pricing.form.fixed_amount'), 'fixed']], {}, { class: "form-select", required: true } %>
            </div>
            <div class="col-md-4">
              <label class="form-label"><%= t('bo.pricing.form.discount_value') %> <span class="text-danger">*</span></label>
              <%= f.number_field :discount_percentage, class: "form-control", placeholder: "0.10", step: 0.01, min: 0, max: 1, required: true %>
              <small class="text-muted"><%= t('bo.pricing.custom_pricing.discount_value_hint') %></small>
            </div>
          </div>

          <div class="row g-3 mt-3">
            <div class="col-md-6">
              <div class="form-check form-switch">
                <%= f.check_box :stackable, class: "form-check-input", role: "switch", id: "stackableSwitch" %>
                <label class="form-check-label" for="stackableSwitch">
                  <%= t('bo.pricing.form.stackable_label') %>
                </label>
              </div>
              <small class="text-muted"><%= t('bo.pricing.form.stackable_hint_custom') %></small>
            </div>
            <div class="col-md-6">
              <div class="form-check form-switch">
                <%= f.check_box :active, class: "form-check-input", role: "switch", id: "activeSwitch", checked: @discount.active.nil? || @discount.active? %>
                <label class="form-check-label" for="activeSwitch">
                  <%= t('bo.pricing.form.active_label') %>
                </label>
              </div>
              <small class="text-muted"><%= t('bo.pricing.form.active_hint') %></small>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title mb-4"><%= t('bo.pricing.custom_pricing.validity_title') %></h5>
          <p class="text-muted small"><%= t('bo.pricing.form.no_expiration') %></p>

          <div class="mb-3">
            <label class="form-label"><%= t('bo.pricing.form.valid_from') %></label>
            <%= f.date_field :valid_from, class: "form-control" %>
          </div>

          <div>
            <label class="form-label"><%= t('bo.pricing.form.valid_until') %></label>
            <%= f.date_field :valid_until, class: "form-control" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%= render partial: "bo/product_discounts/variant_overrides_frame", locals: { variants_grouped: @variants_grouped || {}, currency_symbol: @current_organisation.currency_symbol } %>
<% end %>

</div>

<% end %>
