<% content_for :bo_main_content do %>

<% qr_url = quick_access_url(org_slug: @customer.organisation.slug, token: @token&.token || "TOKEN") %>
<% qr_svg = @token ? RQRCode::QRCode.new(qr_url, level: :m).as_svg(offset: 0, color: "000", shape_rendering: "crispEdges", module_size: 6, standalone: true, use_path: true).html_safe : nil %>

<div class="bo-page-header">
  <div class="d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center gap-3">
      <%= link_to bo_customer_path(params[:org_slug], @customer), class: "text-muted text-decoration-none" do %>
        <i class="fa-solid fa-arrow-left fa-lg"></i>
      <% end %>

      <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold" style="width: 60px; height: 60px; font-size: 1.25rem;">
        <i class="fa-solid fa-qrcode"></i>
      </div>

      <div>
        <h1><%= t("bo.quick_access_tokens.show.title") %></h1>
        <span class="text-muted"><%= @customer_user.contact_name.presence || @customer_user.email %> · <%= @customer.company_name %></span>
      </div>
    </div>

    <% if @token %>
      <div class="bo-page-actions">
        <%= button_to bo_customer_customer_user_quick_access_token_path(org_slug: params[:org_slug], customer_id: @customer.id, customer_user_id: @customer_user.id),
                      method: :post,
                      form: { class: "d-inline" },
                      class: "btn btn-outline-secondary",
                      data: { turbo_confirm: t("bo.quick_access_tokens.show.regenerate_confirm") } do %>
          <i class="fa-solid fa-rotate me-1"></i><%= t("bo.quick_access_tokens.show.regenerate") %>
        <% end %>

        <%= button_to bo_customer_customer_user_quick_access_token_path(org_slug: params[:org_slug], customer_id: @customer.id, customer_user_id: @customer_user.id),
                      method: :delete,
                      form: { class: "d-inline" },
                      class: "btn btn-outline-danger",
                      data: { turbo_confirm: t("bo.quick_access_tokens.show.revoke_confirm") } do %>
          <i class="fa-solid fa-ban me-1"></i><%= t("bo.quick_access_tokens.show.revoke") %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<div class="bo-page-body">
  <div class="row g-3">
    <div class="col-md-6">
      <div class="card">
        <div class="card-body text-center">
          <% if @token %>
            <div class="d-inline-block p-3 border rounded mb-3" style="background:#fff;">
              <%= qr_svg %>
            </div>
            <p class="small text-muted mb-1">
              <% if @token.non_expiring? %>
                <i class="fa-solid fa-infinity me-1"></i><%= t("bo.quick_access_tokens.show.never_expires") %>
              <% else %>
                <%= t("bo.quick_access_tokens.show.expires_at", date: l(@token.expires_at, format: :short)) %>
              <% end %>
            </p>
            <% if @token.last_used_at %>
              <p class="small text-muted mb-0">
                <%= t("bo.quick_access_tokens.show.last_used_at", time: time_ago_in_words(@token.last_used_at)) %>
              </p>
            <% end %>
          <% else %>
            <div class="py-5">
              <i class="fa-solid fa-qrcode fa-3x text-muted mb-3 opacity-50"></i>
              <p class="mb-3"><%= t("bo.quick_access_tokens.show.empty") %></p>
              <% if @customer_user.invitation_status == :active %>
                <%= button_to bo_customer_customer_user_quick_access_token_path(org_slug: params[:org_slug], customer_id: @customer.id, customer_user_id: @customer_user.id),
                              method: :post,
                              class: "btn btn-primary" do %>
                  <i class="fa-solid fa-plus me-1"></i><%= t("bo.quick_access_tokens.show.generate") %>
                <% end %>
              <% else %>
                <div class="alert alert-warning mb-0 mx-auto" style="max-width: 460px;">
                  <i class="fa-solid fa-triangle-exclamation me-1"></i>
                  <%= t("bo.quick_access_tokens.unavailable.#{@customer_user.invitation_status}") %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <% if @token %>
      <div class="col-md-6">
        <div class="card mb-3">
          <div class="card-body">
            <h5 class="card-title mb-3"><%= t("bo.quick_access_tokens.show.download_title") %></h5>
            <p class="text-muted small mb-3"><%= t("bo.quick_access_tokens.show.download_hint") %></p>

            <div class="d-grid gap-2">
              <% [
                ["card",    "fa-id-card"],
                ["sheet",   "fa-table-cells"],
                ["digital", "fa-image"]
              ].each do |fmt, icon| %>
                <% ready = @token.attached_pdf(fmt).attached? %>
                <% url = download_bo_customer_customer_user_quick_access_token_path(org_slug: params[:org_slug], customer_id: @customer.id, customer_user_id: @customer_user.id, layout: fmt) %>
                <% btn_class = "btn btn-outline-primary text-start position-relative #{'disabled' unless ready}" %>
                <% if ready %>
                  <%= link_to url, class: btn_class do %>
                    <i class="fa-solid <%= icon %> me-2"></i>
                    <strong><%= t("bo.quick_access_tokens.formats.#{fmt}") %></strong>
                    <small class="text-muted d-block ms-4"><%= t("bo.quick_access_tokens.formats.#{fmt}_hint") %></small>
                  <% end %>
                <% else %>
                  <span class="<%= btn_class %>" aria-disabled="true" tabindex="-1" style="cursor: not-allowed; opacity: 0.55;">
                    <i class="fa-solid fa-circle-notch fa-spin me-2"></i>
                    <strong><%= t("bo.quick_access_tokens.formats.#{fmt}") %></strong>
                    <small class="d-block ms-4"><%= t("bo.quick_access_tokens.show.format_preparing") %></small>
                  </span>
                <% end %>
              <% end %>
            </div>

            <% if @token.any_pdf_pending? %>
              <% ready_count = QuickAccessToken::PDF_FORMATS.count { |f| @token.attached_pdf(f).attached? } %>
              <% total = QuickAccessToken::PDF_FORMATS.size %>
              <% pct = (ready_count * 100.0 / total).round %>
              <div class="mt-3" data-controller="auto-refresh" data-auto-refresh-interval-value="3000">
                <div class="d-flex justify-content-between align-items-center mb-1">
                  <small class="text-muted">
                    <i class="fa-solid fa-circle-notch fa-spin me-1"></i>
                    <%= t("bo.quick_access_tokens.show.preparing_progress", ready: ready_count, total: total) %>
                  </small>
                  <small class="text-muted"><%= pct %>%</small>
                </div>
                <div class="progress" style="height: 6px;">
                  <div class="progress-bar progress-bar-striped progress-bar-animated"
                       role="progressbar"
                       style="width: <%= pct %>%;"
                       aria-valuenow="<%= pct %>"
                       aria-valuemin="0"
                       aria-valuemax="100"></div>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <% share_phone = @customer_user.contact_phone.presence || @customer.contact_phone %>
        <% share_email = @customer_user.email %>
        <% share_msg = t("bo.quick_access_tokens.share.message_body",
                        company: @customer.organisation.name,
                        url: qr_url) %>
        <% share_subject = t("bo.quick_access_tokens.share.email_subject",
                            company: @customer.organisation.name) %>

        <div class="card mb-3">
          <div class="card-body">
            <h5 class="card-title mb-3"><%= t("bo.quick_access_tokens.show.share_title") %></h5>
            <p class="text-muted small mb-3"><%= t("bo.quick_access_tokens.show.share_hint") %></p>

            <div class="d-grid gap-2">
              <% if (wa_url = whatsapp_share_url(share_phone, share_msg)) %>
                <%= link_to wa_url, target: "_blank", rel: "noopener", class: "btn btn-outline-success text-start" do %>
                  <i class="fa-brands fa-whatsapp me-2"></i>
                  <strong><%= t("bo.quick_access_tokens.share.whatsapp") %></strong>
                  <small class="text-muted d-block ms-4"><%= t("bo.quick_access_tokens.share.whatsapp_hint", phone: share_phone) %></small>
                <% end %>
              <% else %>
                <button type="button" class="btn btn-outline-secondary text-start" disabled>
                  <i class="fa-brands fa-whatsapp me-2"></i>
                  <strong><%= t("bo.quick_access_tokens.share.whatsapp") %></strong>
                  <small class="text-muted d-block ms-4"><%= t("bo.quick_access_tokens.share.no_phone") %></small>
                </button>
              <% end %>

              <% if (sms_url = sms_share_url(share_phone, share_msg)) %>
                <%= link_to sms_url, class: "btn btn-outline-primary text-start" do %>
                  <i class="fa-solid fa-comment-sms me-2"></i>
                  <strong><%= t("bo.quick_access_tokens.share.sms") %></strong>
                  <small class="text-muted d-block ms-4"><%= t("bo.quick_access_tokens.share.sms_hint", phone: share_phone) %></small>
                <% end %>
              <% else %>
                <button type="button" class="btn btn-outline-secondary text-start" disabled>
                  <i class="fa-solid fa-comment-sms me-2"></i>
                  <strong><%= t("bo.quick_access_tokens.share.sms") %></strong>
                  <small class="text-muted d-block ms-4"><%= t("bo.quick_access_tokens.share.no_phone") %></small>
                </button>
              <% end %>

              <% if (email_url = email_share_url(share_email, share_subject, share_msg)) %>
                <%= link_to email_url, class: "btn btn-outline-primary text-start" do %>
                  <i class="fa-solid fa-envelope me-2"></i>
                  <strong><%= t("bo.quick_access_tokens.share.email") %></strong>
                  <small class="text-muted d-block ms-4"><%= t("bo.quick_access_tokens.share.email_hint", email: share_email) %></small>
                <% end %>
              <% end %>

              <button type="button"
                      class="btn btn-outline-secondary text-start"
                      data-controller="copy-to-clipboard"
                      data-copy-to-clipboard-text-value="<%= qr_url %>"
                      data-copy-to-clipboard-copied-label-value="<%= t('bo.quick_access_tokens.share.copied') %>"
                      data-action="click->copy-to-clipboard#copy">
                <i class="fa-solid fa-link me-2"></i>
                <strong data-copy-to-clipboard-target="label"><%= t("bo.quick_access_tokens.share.copy") %></strong>
                <small class="text-muted d-block ms-4 font-monospace text-break" style="word-break: break-all;"><%= qr_url %></small>
              </button>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<% end %>
