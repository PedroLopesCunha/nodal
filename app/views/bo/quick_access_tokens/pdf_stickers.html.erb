<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="utf-8">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    <%= render "bo/quick_access_tokens/pdf_styles", primary_color: @customer.organisation.effective_primary_color || "#111" %>
    /*
      Avery L7163: A4 sheet, 8 labels (2 cols × 4 rows), 99.1×67.7 mm each.
      Top margin 8.5mm, side margin 4.5mm, gap 2.5mm column / 0 row.
    */
    @page { size: A4; margin: 0; }
    html, body { width: 210mm; height: 297mm; margin: 0; padding: 0; }
    .sheet {
      width: 210mm; height: 297mm;
      padding: 8.5mm 4.5mm;
      box-sizing: border-box;
    }
    .grid {
      display: grid;
      grid-template-columns: 99.1mm 99.1mm;
      grid-template-rows: repeat(4, 67.7mm);
      column-gap: 2.5mm;
      row-gap: 0;
    }
    /* Stickers are larger than cards — let the card block fill the label
       and bump the QR + name a touch via the sticker-specific class. */
    .card.sticker {
      width: 99.1mm; height: 67.7mm;
    }
  </style>
</head>
<body>
  <div class="sheet">
    <div class="grid">
      <% 8.times do %>
        <%= render "bo/quick_access_tokens/pdf_card_block",
                   customer: @customer,
                   customer_user: @customer_user,
                   qr_svg: @qr_svg,
                   organisation: @customer.organisation,
                   variant: "sticker" %>
      <% end %>
    </div>
  </div>
</body>
</html>
