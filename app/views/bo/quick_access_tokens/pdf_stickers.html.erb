<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    /*
      Avery L7163 layout: A4 (210×297 mm), 8 labels per sheet,
      label size 99.1×67.7 mm, 2 columns × 4 rows.
      Margins to align with the L7163 die-cut: top 8.5mm, side 4.5mm,
      column gap 2.5mm, row gap 0mm (stacked).
    */
    @page { size: A4; margin: 0; }
    html, body { margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; color: #1a1a1a; }
    .sheet { padding: 8.5mm 4.5mm; }
    .grid {
      display: grid;
      grid-template-columns: 99.1mm 99.1mm;
      grid-template-rows: 67.7mm 67.7mm 67.7mm 67.7mm;
      column-gap: 2.5mm;
      row-gap: 0;
    }
    .label {
      box-sizing: border-box;
      width: 99.1mm; height: 67.7mm;
      padding: 6mm 7mm;
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 5mm;
    }
    .qr { flex: 0 0 auto; width: 50mm; height: 50mm; }
    .qr svg { width: 100%; height: 100%; display: block; }
    .info { flex: 1 1 auto; min-width: 0; }
    .org { font-size: 11pt; font-weight: 700; color: <%= @customer.organisation.effective_primary_color || "#000" %>; margin: 0 0 2mm 0; line-height: 1.1; }
    .company { font-size: 10pt; font-weight: 600; margin: 0 0 1.5mm 0; line-height: 1.15; }
    .contact { font-size: 8pt; color: #6b7280; margin: 0 0 2.5mm 0; line-height: 1.15; }
    .cta { font-size: 7pt; color: #9ca3af; margin: 0; line-height: 1.2; }
  </style>
</head>
<body>
  <div class="sheet">
    <div class="grid">
      <% 8.times do %>
        <div class="label">
          <div class="qr"><%= @qr_svg.html_safe %></div>
          <div class="info">
            <p class="org"><%= @customer.organisation.name %></p>
            <p class="company"><%= @customer.company_name %></p>
            <% if @customer_user.contact_name.present? %>
              <p class="contact"><%= @customer_user.contact_name %></p>
            <% end %>
            <p class="cta"><%= t("bo.quick_access_tokens.pdf.cta") %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</body>
</html>
