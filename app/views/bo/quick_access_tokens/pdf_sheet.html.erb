<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    @page { size: A4; margin: 10mm; }
    html, body { margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; color: #1a1a1a; }
    .grid { display: grid; grid-template-columns: 85mm 85mm; grid-template-rows: 55mm 55mm 55mm 55mm; gap: 5mm 10mm; }
    .card {
      box-sizing: border-box;
      width: 85mm; height: 55mm;
      padding: 4mm 4mm;
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 4mm;
      border: 1px dashed #c0c0c0;
    }
    .qr { flex: 0 0 auto; width: 38mm; height: 38mm; }
    .qr svg { width: 100%; height: 100%; display: block; }
    .info { flex: 1 1 auto; min-width: 0; }
    .org { font-size: 9pt; font-weight: 700; color: <%= @customer.organisation.effective_primary_color || "#000" %>; margin: 0 0 1.5mm 0; line-height: 1.1; }
    .company { font-size: 8pt; font-weight: 600; margin: 0 0 1mm 0; line-height: 1.15; }
    .contact { font-size: 7pt; color: #6b7280; margin: 0 0 2mm 0; line-height: 1.15; }
    .cta { font-size: 6pt; color: #9ca3af; margin: 0; line-height: 1.2; }
  </style>
</head>
<body>
  <div class="grid">
    <% 8.times do %>
      <div class="card">
        <div class="qr"><%= @qr_svg.html_safe %></div>
        <div class="info">
          <p class="org"><%= @customer.organisation.name %></p>
          <p class="company"><%= @customer.company_name %></p>
          <% if @customer_user.contact_name.present? %>
            <p class="contact"><%= @customer_user.contact_name %></p>
          <% end %>
          <p class="cta"><%= t("bo.quick_access_tokens.pdf.cta") %></p>
        </div>
      </div>
    <% end %>
  </div>
</body>
</html>
