<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="utf-8">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    <%= render "bo/quick_access_tokens/pdf_styles", primary_color: @customer.organisation.effective_primary_color || "#111" %>

    html, body { width: 1080px; height: 1080px; margin: 0; padding: 0; background: #f5f5f5; }
    .stage {
      width: 1080px; height: 1080px;
      display: flex; align-items: center; justify-content: center;
      padding: 60px;
      box-sizing: border-box;
    }
    .digital-card {
      width: 100%; height: 100%;
      background: #ffffff;
      border-radius: 28px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.10);
      padding: 50px 56px;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      gap: 24px;
    }
    .digital-card .head {
      display: flex; align-items: center; justify-content: space-between;
    }
    .digital-card .head .org-name {
      font-size: 18px; letter-spacing: 0.6px; color: #999; text-transform: uppercase; font-weight: 500;
    }
    .digital-card .head .org-logo { height: 64px; max-width: 240px; object-fit: contain; }

    .digital-card .qr-wrap {
      align-self: center;
      width: 420px; height: 420px;
      background: #fff;
      border-radius: 20px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.08);
      padding: 18px;
      box-sizing: border-box;
    }
    .digital-card .qr-wrap svg { width: 100% !important; height: 100% !important; display: block; }

    .digital-card .cta {
      text-align: center;
    }
    .digital-card .cta .label {
      font-size: 24px; font-weight: 600; color: #111;
    }
    .digital-card .cta .sub { font-size: 16px; color: #777; margin-top: 4px; }

    .digital-card .who {
      border-top: 1px solid #eee; padding-top: 20px; text-align: center;
    }
    .digital-card .who .name { font-size: 28px; font-weight: 600; color: #111; }
    .digital-card .who .company { font-size: 18px; color: <%= @customer.organisation.effective_primary_color || "#555" %>; font-weight: 500; margin-top: 4px; }

    .digital-card .contacts {
      text-align: center;
      font-size: 16px; color: #444; line-height: 1.6;
    }
    .digital-card .contacts .row { display: block; }

    .digital-card .footer {
      font-size: 13px; color: #aaa; text-align: center; margin-top: auto;
    }
  </style>
</head>
<body>
  <div class="stage">
    <div class="digital-card">
      <div class="head">
        <div class="org-name"><%= @customer.organisation.name %></div>
        <% if logo_data = org_logo_data_url(@customer.organisation) %>
          <img class="org-logo" src="<%= logo_data %>" alt="">
        <% end %>
      </div>

      <div class="qr-wrap"><%= @qr_svg.html_safe %></div>

      <div class="cta">
        <div class="label"><%= t("bo.quick_access_tokens.pdf.cta_label") %></div>
        <div class="sub"><%= t("bo.quick_access_tokens.pdf.cta_sub") %></div>
      </div>

      <div class="who">
        <div class="name"><%= @customer_user.contact_name.presence || @customer_user.email %></div>
        <% if @customer.company_name.present? %>
          <div class="company"><%= @customer.company_name %></div>
        <% end %>
      </div>

      <div class="contacts">
        <% [@customer.organisation.phone, @customer.organisation.whatsapp, @customer.organisation.contact_email].compact_blank.uniq.each do |line| %>
          <span class="row"><%= line %></span>
        <% end %>
      </div>

      <div class="footer"><%= t("bo.quick_access_tokens.pdf.footer") %></div>
    </div>
  </div>
</body>
</html>
