<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="utf-8">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }

    @page { size: 105mm 148mm; margin: 0; }
    html, body { width: 105mm; height: 148mm; margin: 0; padding: 0; background: #f5f5f5; }

    .stage {
      width: 105mm; height: 148mm;
      padding: 6mm;
      box-sizing: border-box;
    }
    .digital-card {
      width: 100%; height: 100%;
      background: #ffffff;
      border-radius: 4mm;
      padding: 8mm 9mm;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      gap: 4mm;
    }
    .digital-card .head {
      display: flex; align-items: center; justify-content: space-between;
      gap: 3mm;
    }
    .digital-card .head .org-name {
      font-size: 8pt; letter-spacing: 0.5px; color: #999; text-transform: uppercase; font-weight: 500;
    }
    .digital-card .head .org-logo { height: 9mm; max-width: 28mm; object-fit: contain; }

    .digital-card .qr-wrap {
      align-self: center;
      width: 60mm; height: 60mm;
      background: #fff;
      border-radius: 3mm;
      padding: 2mm;
      box-sizing: border-box;
    }
    .digital-card .qr-wrap svg { width: 100% !important; height: 100% !important; display: block; }

    .digital-card .cta { text-align: center; }
    .digital-card .cta .label { font-size: 11pt; font-weight: 600; color: #111; line-height: 1.2; }
    .digital-card .cta .sub { font-size: 8pt; color: #777; margin-top: 1mm; line-height: 1.2; }

    .digital-card .who {
      border-top: 1px solid #eee; padding-top: 3mm; text-align: center;
    }
    .digital-card .who .name { font-size: 12pt; font-weight: 600; color: #111; line-height: 1.2; }
    .digital-card .who .company { font-size: 9pt; color: <%= @customer.organisation.effective_primary_color || "#555" %>; font-weight: 500; margin-top: 1mm; line-height: 1.2; }

    .digital-card .contacts {
      text-align: center;
      font-size: 8pt; color: #444; line-height: 1.55;
    }
    .digital-card .contacts .row { display: block; }

    .digital-card .footer {
      font-size: 6.5pt; color: #aaa; text-align: center; margin-top: auto;
    }
  </style>
</head>
<body>
  <div class="stage">
    <div class="digital-card">
      <div class="head">
        <div class="org-name"><%= @customer.organisation.name %></div>
        <% if logo_data = org_logo_data_url(@customer.organisation) %>
          <img class="org-logo" src="<%= logo_data %>" alt="">
        <% end %>
      </div>

      <div class="qr-wrap"><%= @qr_svg.html_safe %></div>

      <div class="cta">
        <div class="label"><%= t("bo.quick_access_tokens.pdf.cta_label") %></div>
        <div class="sub"><%= t("bo.quick_access_tokens.pdf.cta_sub") %></div>
      </div>

      <div class="who">
        <div class="name"><%= @customer_user.contact_name.presence || @customer_user.email %></div>
        <% if @customer.company_name.present? %>
          <div class="company"><%= @customer.company_name %></div>
        <% end %>
      </div>

      <div class="contacts">
        <% [@customer.organisation.phone, @customer.organisation.whatsapp, @customer.organisation.contact_email].compact_blank.uniq.each do |line| %>
          <span class="row"><%= line %></span>
        <% end %>
      </div>

      <div class="footer">
        <%= t("bo.quick_access_tokens.pdf.generated_on", date: l(@token.created_at.to_date)) %><% unless @token.non_expiring? %> · <%= t("bo.quick_access_tokens.pdf.expires_on", date: l(@token.expires_at.to_date)) %><% end %>
      </div>
    </div>
  </div>
</body>
</html>
