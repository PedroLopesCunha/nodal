<turbo-frame id="catalog_selection">
  <%# Search form %>
  <div class="mb-3">
    <div class="input-group input-group-sm">
      <span class="input-group-text bg-white"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
      <%= form_with url: catalog_selection_bo_products_path(params[:org_slug]), method: :get, data: { turbo_frame: "catalog_selection" }, local: false, class: "flex-grow-1 d-flex" do %>
        <input type="text" name="query" class="form-control border-start-0"
               value="<%= params[:query] %>"
               placeholder="<%= t('bo.catalog.selection.search_placeholder') %>"
               data-catalog-target="searchInput"
               data-action="input->catalog#debouncedSearch"
               autocomplete="off">
        <% if params[:query].present? %>
          <a href="<%= catalog_selection_bo_products_path(params[:org_slug]) %>"
             data-turbo-frame="catalog_selection"
             class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-times"></i>
          </a>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Select/Deselect all %>
  <div class="mb-2 d-flex gap-3">
    <a href="#" class="small text-decoration-none" data-action="click->catalog#selectAllVisible"><%= t('bo.export.select_all') %></a>
    <a href="#" class="small text-decoration-none text-muted" data-action="click->catalog#deselectAll"><%= t('bo.export.deselect_all') %></a>
  </div>

  <%# Content area %>
  <div class="border rounded" style="max-height: 400px; overflow-y: auto;">
    <% if @search_mode %>
      <%# Flat search results %>
      <% if @products.any? %>
        <% @products.each do |product| %>
          <div class="border-bottom" data-catalog-role="product-row">
            <div class="d-flex align-items-center px-3 py-2">
              <input type="checkbox" class="form-check-input me-2 product-checkbox"
                     value="<%= product.id %>"
                     data-action="change->catalog#toggleProduct">
              <i class="fa-solid fa-cube text-muted me-2 small"></i>
              <span class="small"><%= product.name %></span>
              <% if product.sku.present? %>
                <span class="ms-2 small text-muted font-monospace"><%= product.sku %></span>
              <% end %>
              <% if product.primary_category.present? %>
                <span class="ms-auto badge bg-light text-muted small"><%= product.primary_category.full_path %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-4">
          <p class="text-muted small mb-0"><%= t('bo.common.no_results', default: 'No results found.') %></p>
        </div>
      <% end %>
    <% else %>
      <%# Category tree (browse mode) %>
      <% @categories.each do |category| %>
        <% category_products = category.products.where(organisation: current_organisation).order(:name) %>
        <div class="border-bottom" data-catalog-role="category-row">
          <div class="d-flex align-items-center px-3 py-2">
            <% has_children = category.children.kept.any? || category_products.any? %>
            <% if has_children %>
              <a href="#" class="text-muted me-2" data-action="click->catalog#toggleExpand" style="width: 16px;">
                <i class="fa-solid fa-chevron-right small"></i>
              </a>
            <% else %>
              <span style="width: 16px;" class="me-2"></span>
            <% end %>
            <input type="checkbox" class="form-check-input me-2 category-checkbox"
                   value="<%= category.id %>"
                   data-action="change->catalog#toggleCategory">
            <i class="fa-solid fa-folder text-warning me-2"></i>
            <span class="fw-medium"><%= category.full_path %></span>
            <span class="badge bg-light text-muted ms-2"><%= category_products.count %></span>
          </div>

          <% if has_children %>
            <div class="category-children d-none ps-4">
              <%# Subcategories %>
              <% category.children.kept.order(:name).each do |child| %>
                <% child_products = child.products.where(organisation: current_organisation).order(:name) %>
                <div class="border-top" data-catalog-role="category-row">
                  <div class="d-flex align-items-center px-3 py-2">
                    <% has_child_products = child_products.any? || child.children.kept.any? %>
                    <% if has_child_products %>
                      <a href="#" class="text-muted me-2" data-action="click->catalog#toggleExpand" style="width: 16px;">
                        <i class="fa-solid fa-chevron-right small"></i>
                      </a>
                    <% else %>
                      <span style="width: 16px;" class="me-2"></span>
                    <% end %>
                    <input type="checkbox" class="form-check-input me-2 category-checkbox"
                           value="<%= child.id %>"
                           data-action="change->catalog#toggleCategory">
                    <i class="fa-solid fa-folder text-warning me-2"></i>
                    <span><%= child.name %></span>
                    <span class="badge bg-light text-muted ms-2"><%= child_products.count %></span>
                  </div>

                  <% if has_child_products %>
                    <div class="category-children d-none ps-4">
                      <% child_products.each do |product| %>
                        <div class="border-top" data-catalog-role="product-row">
                          <div class="d-flex align-items-center px-3 py-1">
                            <span style="width: 16px;" class="me-2"></span>
                            <input type="checkbox" class="form-check-input me-2 product-checkbox"
                                   value="<%= product.id %>"
                                   data-action="change->catalog#toggleProduct">
                            <i class="fa-solid fa-cube text-muted me-2 small"></i>
                            <span class="small"><%= product.name %></span>
                            <% if product.sku.present? %>
                              <span class="ms-2 small text-muted font-monospace"><%= product.sku %></span>
                            <% end %>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>

              <%# Direct products %>
              <% category_products.each do |product| %>
                <div class="border-top" data-catalog-role="product-row">
                  <div class="d-flex align-items-center px-3 py-1">
                    <span style="width: 16px;" class="me-2"></span>
                    <input type="checkbox" class="form-check-input me-2 product-checkbox"
                           value="<%= product.id %>"
                           data-action="change->catalog#toggleProduct">
                    <i class="fa-solid fa-cube text-muted me-2 small"></i>
                    <span class="small"><%= product.name %></span>
                    <% if product.sku.present? %>
                      <span class="ms-2 small text-muted font-monospace"><%= product.sku %></span>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <% if @search_mode && @pagy.pages > 1 %>
    <div class="d-flex justify-content-center mt-3">
      <%== pagy_bootstrap_nav(@pagy) %>
    </div>
  <% end %>
</turbo-frame>
