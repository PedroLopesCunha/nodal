<% content_for :bo_main_content do %>

<div class="bo-page-header">
  <div class="d-flex justify-content-between align-items-start">
    <div class="d-flex align-items-center gap-3">
      <%= link_to bo_products_path(params[:org_slug], filter_params_hash), class: "text-muted text-decoration-none" do %>
        <i class="fa-solid fa-arrow-left fa-lg"></i>
      <% end %>
      <div>
        <h1><%= @product.name %></h1>
        <p>SKU: <%= @product.sku %></p>
      </div>
    </div>
    <div class="bo-page-actions">
      <%= link_to product_path(params[:org_slug], @product), class: "btn btn-outline-secondary", target: "_blank" do %>
        <i class="fa-solid fa-store me-1"></i> <%= t('bo.products.show.view_in_storefront') %>
      <% end %>
      <%= link_to related_products_bo_product_path(params[:org_slug], @product), class: "btn btn-outline-secondary" do %>
        <i class="fa-solid fa-link me-1"></i> <%= t('bo.products.show.manage_related') %>
      <% end %>
      <%= link_to configure_variants_bo_product_path(params[:org_slug], @product), class: "btn btn-outline-secondary" do %>
        <i class="fa-solid fa-cubes me-1"></i> <%= t('bo.products.show.manage_variants') %>
      <% end %>
      <%= link_to edit_bo_product_path(params[:org_slug], @product, filter_params_hash), class: "btn btn-outline-primary" do %>
        <i class="fa-solid fa-pen-to-square me-1"></i> <%= t('bo.common.actions.edit') %>
      <% end %>
      <%= link_to bo_product_path(params[:org_slug], @product, filter_params_hash),
          class: "btn btn-outline-danger",
          data: { turbo_method: :delete, turbo_confirm: t('bo.common.confirm.delete_product_name', name: @product.name) } do %>
        <i class="fa-solid fa-trash me-1"></i> <%= t('bo.common.actions.delete') %>
      <% end %>
    </div>
  </div>
</div>

<div class="bo-page-body">
<div class="row g-4">
  <%# Left Column %>
  <div class="col-lg-8">
    <%# Product Information Card %>
    <div class="card mb-4">
      <div class="card-body">
        <h5 class="card-title mb-3"><%= t('bo.products.show.product_information') %></h5>

        <div class="mb-3">
          <small class="text-muted d-block"><%= t('bo.products.form.description') %></small>
          <p class="mb-0"><%= @product.description %></p>
        </div>

        <hr>

        <div class="row">
          <div class="col-md-6 mb-3">
            <small class="text-muted d-block"><%= t('bo.products.form.categories') %></small>
            <% if @product.categories.any? %>
              <div class="d-flex flex-wrap gap-1">
                <% @product.categories.each do |category| %>
                  <%= link_to bo_category_path(params[:org_slug], category), class: "badge bg-secondary text-decoration-none" do %>
                    <%= category.full_path %>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <span class="text-muted">-</span>
            <% end %>
          </div>
          <div class="col-md-6 mb-3">
            <small class="text-muted d-block"><%= t('bo.products.form.unit_price', currency: @current_organisation.currency_symbol) %></small>
            <% if @product.price_on_request? %>
              <span class="badge bg-warning-subtle text-warning"><i class="fa-solid fa-tag me-1"></i><%= t('bo.products.form.price_on_request') %></span>
            <% else %>
              <strong><%= humanized_money_with_symbol(@product.price) || '-'  %></strong>
            <% end %>
          </div>
          <div class="col-md-6 mb-3">
            <small class="text-muted d-block"><%= t('bo.products.form.unit_description') %></small>
            <strong><%= @product.unit_description || '-' %></strong>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <small class="text-muted d-block"><%= t('bo.products.form.min_quantity') %></small>
            <strong><%= @product.min_quantity %></strong>
          </div>
          <div class="col-md-6 mb-3">
            <small class="text-muted d-block"><%= t('bo.products.form.min_quantity_type') %></small>
            <strong><%= @product.min_quantity_type || t('bo.products.form.units') %></strong>
          </div>
        </div>

        <% variant_attrs = @product.default_variant&.attribute_values&.joins(:product_attribute)&.includes(:product_attribute)&.order('product_attributes.position') %>
        <% if variant_attrs.present? && variant_attrs.any? %>
          <div class="row">
            <% variant_attrs.group_by(&:product_attribute).each do |attribute, values| %>
              <div class="col-md-6 mb-3">
                <small class="text-muted d-block"><%= attribute.name %></small>
                <strong><%= values.map(&:value).join(', ') %></strong>
              </div>
            <% end %>
          </div>
        <% end %>

        <hr>

        <div>
          <small class="text-muted d-block mb-2"><%= t('bo.products.form.product_images') %></small>
          <% all_photos = @product.all_photos %>
          <% if all_photos.any? %>
            <div class="d-flex flex-wrap gap-2" data-controller="lightbox">
              <% main_blob_id = @product.cover_photo_blob_id || all_photos.first&.blob_id %>
              <% all_photos.each do |photo| %>
                <div class="border rounded p-1 position-relative" style="width: 120px;">
                  <a href="#" data-action="lightbox#open" data-lightbox-url="<%= url_for(photo) %>" style="cursor: zoom-in;">
                    <%= image_tag photo, style: "width: 100%; height: 100px; object-fit: cover; border-radius: 4px;" %>
                  </a>
                  <% if photo.blob_id == main_blob_id %>
                    <span class="badge bg-primary position-absolute" style="bottom: 4px; left: 4px; font-size: 10px;"><%= t('bo.products.show.main') %></span>
                  <% end %>
                </div>
              <% end %>
              <%= render "shared/lightbox" %>
            </div>
          <% else %>
            <p class="text-muted mb-0"><%= t('bo.products.show.no_images') %></p>
          <% end %>
        </div>
      </div>
    </div>

    <%# Variants Card %>
    <div class="card mb-4">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h5 class="card-title mb-0"><%= t('bo.products.show.variants_title') %></h5>
          <%= link_to bo_product_variants_path(params[:org_slug], @product), class: "btn btn-sm btn-outline-primary" do %>
            <i class="fa-solid fa-cubes me-1"></i> <%= t('bo.products.show.view_all_variants') %>
          <% end %>
        </div>

        <div class="row mb-3">
          <div class="col-md-4">
            <small class="text-muted d-block"><%= t('bo.products.show.variant_type') %></small>
            <% if @product.has_variants? %>
              <span class="badge bg-primary"><%= t('bo.products.show.variable_product') %></span>
            <% else %>
              <span class="badge bg-secondary"><%= t('bo.products.show.simple_product') %></span>
            <% end %>
          </div>
          <div class="col-md-4">
            <small class="text-muted d-block"><%= t('bo.products.show.total_variants') %></small>
            <strong><%= @product.product_variants.count %></strong>
          </div>
          <div class="col-md-4">
            <small class="text-muted d-block"><%= t('bo.products.show.price_range') %></small>
            <strong><%= @product.display_price %></strong>
          </div>
        </div>

        <% if @product.product_variants.any? %>
          <table class="table table-sm mb-0">
            <thead>
              <tr>
                <th><%= t('bo.products.show.variant') %></th>
                <th><%= t('bo.products.show.sku') %></th>
                <th><%= t('bo.products.show.price') %></th>
                <th><%= t('bo.products.show.stock') %></th>
                <th><%= t('bo.products.show.status') %></th>
                <th><%= t('bo.products.show.storefront_column') %></th>
              </tr>
            </thead>
            <tbody>
              <% @product.product_variants.by_position.limit(5).each do |variant| %>
                <tr>
                  <td>
                    <%= variant.option_values_string.presence || t('bo.products.show.default') %>
                    <% if variant.is_default? %>
                      <span class="badge bg-info ms-1"><%= t('bo.products.show.default') %></span>
                    <% end %>
                  </td>
                  <td><code><%= variant.sku.presence || '-' %></code></td>
                  <td><%= variant.price&.format %></td>
                  <td>
                    <% if variant.track_stock? %>
                      <span class="text-<%= variant.in_stock? ? 'success' : 'danger' %>"><%= variant.stock_quantity %></span>
                    <% else %>
                      <span class="text-muted"><%= t('bo.products.show.unlimited') %></span>
                    <% end %>
                  </td>
                  <td>
                    <% if variant.published? %>
                      <span class="text-success"><i class="fa-solid fa-check"></i></span>
                    <% else %>
                      <span class="text-danger"><i class="fa-solid fa-times"></i></span>
                    <% end %>
                  </td>
                  <td>
                    <% if variant.is_default? && @product.has_variants? %>
                      <span class="badge bg-light text-muted"><%= t('bo.products.show.variant_storefront_base') %></span>
                    <% elsif !variant.published? %>
                      <span class="badge bg-secondary"><%= t('bo.products.show.variant_storefront_unpublished') %></span>
                    <% elsif variant.purchasable? %>
                      <span class="badge bg-success"><%= t('bo.products.show.variant_storefront_purchasable') %></span>
                    <% elsif !variant.in_stock? && variant.effective_stock_policy == 'show_badge' %>
                      <span class="badge bg-warning text-dark"><%= t('bo.products.show.variant_storefront_badge_no_stock') %></span>
                    <% elsif !variant.in_stock? && variant.effective_stock_policy == 'hide' %>
                      <span class="badge bg-danger"><%= t('bo.products.show.variant_storefront_hidden') %></span>
                    <% elsif !variant.in_stock? %>
                      <span class="badge bg-warning text-dark"><%= t('bo.products.show.variant_storefront_visible_no_stock') %></span>
                    <% else %>
                      <span class="badge bg-success"><%= t('bo.products.show.variant_storefront_purchasable') %></span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
          <% if @product.product_variants.count > 5 %>
            <p class="text-muted small mt-2 mb-0">
              <%= t('bo.products.show.and_more_variants', count: @product.product_variants.count - 5) %>
            </p>
          <% end %>
        <% else %>
          <p class="text-muted mb-0"><%= t('bo.products.show.no_variants') %></p>
        <% end %>
      </div>
    </div>

  </div>

  <%# Right Column — Info Cards %>
  <div class="col-lg-4">
    <%# Card A: ERP Sync Status %>
    <% synced_variants = @product.product_variants.synced_from_erp %>
    <% if synced_variants.any? %>
      <div class="card mb-4">
        <div class="card-body">
          <h6 class="card-title mb-3"><i class="fa-solid fa-rotate me-1"></i> <%= t('bo.erp_sync.title') %></h6>

          <div class="mb-2">
            <small class="text-muted d-block"><%= t('bo.erp_sync.status_label') %></small>
            <% if synced_variants.with_sync_errors.any? %>
              <span class="badge bg-danger"><%= t('bo.erp_sync.error') %></span>
            <% else %>
              <span class="badge bg-success"><%= t('bo.erp_sync.synced') %></span>
            <% end %>
          </div>

          <div class="mb-2">
            <small class="text-muted d-block"><%= t('bo.erp_sync.synced_variants') %></small>
            <% synced_variants.each do |variant| %>
              <div><code><%= variant.external_id %></code> <small class="text-muted"><%= variant.name %></small></div>
            <% end %>
          </div>

          <% last_synced = synced_variants.maximum(:last_synced_at) %>
          <% if last_synced %>
            <div class="mb-2">
              <small class="text-muted d-block"><%= t('bo.erp_sync.last_synced') %></small>
              <span title="<%= l(last_synced) %>"><%= t('bo.erp_sync.synced_ago', time: time_ago_in_words(last_synced)) %></span>
            </div>
          <% end %>

          <% error_variants = synced_variants.with_sync_errors %>
          <% error_variants.each do |variant| %>
            <div class="border border-danger rounded bg-danger-subtle py-2 px-3 mb-0 mt-2">
              <small class="text-danger"><i class="fa-solid fa-triangle-exclamation me-1"></i> <%= variant.sku %>: <%= variant.sync_error %></small>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Card B: Storefront Visibility & Stock Rules %>
    <div class="card mb-4">
      <div class="card-body">
        <h6 class="card-title mb-3"><i class="fa-solid fa-eye me-1"></i> <%= t('bo.products.show.storefront_visibility') %></h6>

        <%# Net result: what does the customer see? %>
        <div class="mb-3">
          <small class="text-muted d-block mb-1"><%= t('bo.products.show.storefront_result') %></small>
          <%
            strategy = current_organisation.out_of_stock_strategy
            if !@product.published?
              product_visible = false
              hidden_reason = :unpublished
            elsif !@product.available?
              # Check if any variant has a non-hide policy (would still show)
              product_visible = @product.product_variants.published.where(is_default: false).any? { |v|
                v.effective_stock_policy != 'hide'
              }
              hidden_reason = :out_of_stock unless product_visible
            else
              product_visible = true
            end
          %>
          <% if product_visible %>
            <div class="border rounded p-2 bg-success-subtle">
              <i class="fa-solid fa-circle-check text-success me-1"></i>
              <strong><%= t('bo.products.show.product_visible_in_storefront') %></strong>
            </div>
          <% else %>
            <div class="border rounded p-2 bg-danger-subtle">
              <i class="fa-solid fa-circle-xmark text-danger me-1"></i>
              <strong><%= t('bo.products.show.product_hidden_from_storefront') %></strong>
              <% if hidden_reason == :unpublished %>
                <small class="text-muted d-block mt-1"><%= t('bo.products.show.hidden_reason_unpublished') %></small>
              <% elsif hidden_reason == :out_of_stock %>
                <small class="text-muted d-block mt-1"><%= t('bo.products.show.hidden_reason_all_out_of_stock') %></small>
              <% end %>
            </div>
          <% end %>
        </div>

        <%# Per-variant storefront status %>
        <% variants = @product.product_variants.by_position %>
        <% if variants.any? %>
          <small class="text-muted d-block mb-2"><%= t('bo.products.show.variant_storefront_status') %></small>
          <ul class="list-unstyled mb-0 small">
            <% variants.each do |variant| %>
              <li class="mb-2 border-bottom pb-2">
                <strong><%= variant.sku.presence || variant.name %></strong>
                <small class="text-muted">(<%= variant.option_values_string.presence || t('bo.products.show.default') %>)</small>
                <div class="ms-3 mt-1">
                  <% if variant.is_default? && @product.has_variants? %>
                    <i class="fa-solid fa-circle text-muted me-1" style="font-size: 8px; vertical-align: middle;"></i>
                    <%= t('bo.products.show.variant_result_base_variant') %>
                  <% elsif !variant.published? %>
                    <i class="fa-solid fa-circle text-secondary me-1" style="font-size: 8px; vertical-align: middle;"></i>
                    <%= t('bo.products.show.variant_result_unpublished') %>
                  <% elsif variant.purchasable? %>
                    <i class="fa-solid fa-circle text-success me-1" style="font-size: 8px; vertical-align: middle;"></i>
                    <%= t('bo.products.show.variant_result_purchasable') %>
                  <% elsif !variant.in_stock? && variant.effective_stock_policy == 'show_badge' %>
                    <i class="fa-solid fa-circle text-warning me-1" style="font-size: 8px; vertical-align: middle;"></i>
                    <%= t('bo.products.show.variant_result_badge_no_stock') %>
                  <% elsif !variant.in_stock? && variant.effective_stock_policy == 'hide' %>
                    <i class="fa-solid fa-circle text-danger me-1" style="font-size: 8px; vertical-align: middle;"></i>
                    <%= t('bo.products.show.variant_result_hidden') %>
                  <% elsif !variant.in_stock? %>
                    <i class="fa-solid fa-circle text-warning me-1" style="font-size: 8px; vertical-align: middle;"></i>
                    <%= t('bo.products.show.variant_result_visible_not_purchasable') %>
                  <% else %>
                    <i class="fa-solid fa-circle text-success me-1" style="font-size: 8px; vertical-align: middle;"></i>
                    <%= t('bo.products.show.variant_result_purchasable') %>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
        <% end %>

        <hr>

        <%# Strategy info %>
        <div class="mb-2">
          <small class="text-muted d-block"><%= t('bo.products.show.stock_strategy') %></small>
          <% case current_organisation.out_of_stock_strategy %>
          <% when 'do_nothing' %>
            <span class="badge bg-secondary"><%= t('bo.products.show.stock_do_nothing') %></span>
          <% when 'deactivate' %>
            <span class="badge bg-warning text-dark"><%= t('bo.products.show.stock_deactivate') %></span>
          <% when 'hide' %>
            <span class="badge bg-danger"><%= t('bo.products.show.stock_hide') %></span>
          <% end %>
          <small class="text-muted d-block mt-1">
            <% case current_organisation.out_of_stock_strategy %>
            <% when 'do_nothing' %>
              <%= t('bo.products.show.stock_do_nothing_desc') %>
            <% when 'deactivate' %>
              <%= t('bo.products.show.stock_deactivate_desc') %>
            <% when 'hide' %>
              <%= t('bo.products.show.stock_hide_desc') %>
            <% end %>
          </small>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<% end %>
