<div class="card mb-4">
  <div class="card-body p-0">
    <ul class="nav nav-pills nav-fill border-bottom" role="tablist">
      <li class="nav-item" role="presentation">
        <%= link_to bo_products_path(params[:org_slug]),
            class: "nav-link rounded-0 py-3 #{'active' if action_name == 'index'}" do %>
          <i class="fa-solid fa-box me-2"></i><%= t('bo.products.tabs.catalog') %>
        <% end %>
      </li>
      <li class="nav-item" role="presentation">
        <%= link_to stock_control_bo_products_path(params[:org_slug]),
            class: "nav-link rounded-0 py-3 #{'active' if action_name == 'stock_control'}" do %>
          <i class="fa-solid fa-warehouse me-2"></i><%= t('bo.products.tabs.stock_control') %>
        <% end %>
      </li>
    </ul>
  </div>
</div>
