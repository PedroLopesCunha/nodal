<% content_for :bo_main_content do %>

<script>
  document.addEventListener('turbo:load', function() {
    document.querySelectorAll('.carteira-row').forEach(row => {
      row.addEventListener('click', function() {
        window.location.href = this.dataset.href;
      });
    });
  });
</script>

<div class="bo-page-header">
  <div class="d-flex justify-content-between align-items-start">
    <div>
      <h1>A minha carteira</h1>
      <p>Clientes atribuídos a ti como vendedor.</p>
    </div>
    <div class="bo-page-actions">
      <%= link_to new_bo_customer_path(org_slug: current_organisation.slug), class: "btn btn-primary" do %>
        <i class="fa-solid fa-plus me-1"></i> Novo cliente
      <% end %>
    </div>
  </div>
</div>

<div class="bo-page-body">

  <%# === Meus números (this month vs last) === %>
  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <small class="text-muted d-block">Encomendas este mês</small>
          <h3 class="mb-0 mt-1"><%= @kpi_orders_this_month %></h3>
          <small class="text-muted">vs <%= @kpi_orders_last_month %> no mês anterior</small>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <small class="text-muted d-block">Volume este mês</small>
          <h3 class="mb-0 mt-1"><%= humanized_money_with_symbol(@kpi_revenue_this_month) %></h3>
          <small class="text-muted">vs <%= humanized_money_with_symbol(@kpi_revenue_last_month) %> no mês anterior</small>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <small class="text-muted d-block">Encomenda média</small>
          <h3 class="mb-0 mt-1"><%= humanized_money_with_symbol(@kpi_aov_this_month) %></h3>
          <small class="text-muted">vs <%= humanized_money_with_symbol(@kpi_aov_last_month) %> no mês anterior</small>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card h-100 <%= 'border-info' if @kpi_open_carts > 0 %>"
           <% if @kpi_open_carts > 0 %>style="cursor: pointer;" data-bs-toggle="modal" data-bs-target="#openCartsModal"<% end %>>
        <div class="card-body">
          <small class="text-muted d-block">Carrinhos abertos</small>
          <div class="d-flex justify-content-between align-items-baseline mt-1">
            <h3 class="mb-0"><%= @kpi_open_carts %></h3>
            <span class="text-muted small"><%= humanized_money_with_symbol(@kpi_open_carts_total) %></span>
          </div>
          <small class="text-muted">
            <% if @kpi_open_carts > 0 %>
              <i class="fa-solid fa-arrow-up-right-from-square fa-xs me-1"></i>clica para ver detalhe
            <% else %>
              sem carrinhos pendentes
            <% end %>
          </small>
        </div>
      </div>
    </div>
  </div>

  <%# === Search + filters === %>
  <div class="card mb-4">
    <div class="card-body">
      <%= form_with url: bo_sales_rep_carteira_path(org_slug: current_organisation.slug), method: :get do %>
        <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
        <%= hidden_field_tag :direction, params[:direction] if params[:direction].present? %>
        <div class="d-flex align-items-center mb-0">
          <div class="input-group flex-grow-1 me-3">
            <span class="input-group-text bg-white border-end-0">
              <i class="fa-solid fa-magnifying-glass text-muted"></i>
            </span>
            <%= text_field_tag :query, params[:query],
                  class: "form-control border-start-0",
                  placeholder: "Pesquisar por nome, empresa, email ou NIF…" %>
          </div>
          <button type="submit" class="btn btn-outline-secondary me-2">
            <i class="fa-solid fa-magnifying-glass"></i> Procurar
          </button>
          <% if carteira_filter_params_hash.except(:sort, :direction).any? %>
            <%= link_to bo_sales_rep_carteira_path(org_slug: current_organisation.slug), class: "btn btn-outline-danger" do %>
              <i class="fa-solid fa-xmark"></i> Limpar
            <% end %>
          <% end %>
        </div>
        <div class="row mt-3">
          <div class="col-md-4">
            <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
              <option value="">Todos os estados de portal</option>
              <option value="active" <%= 'selected' if params[:status] == 'active' %>>Activo (login criado)</option>
              <option value="pending" <%= 'selected' if params[:status] == 'pending' %>>Pendente (convidado)</option>
              <option value="not_invited" <%= 'selected' if params[:status] == 'not_invited' %>>Sem login criado</option>
              <option value="inactive" <%= 'selected' if params[:status] == 'inactive' %>>Inativo</option>
            </select>
          </div>
          <% if erp_customer_sync_enabled? %>
            <div class="col-md-4">
              <select name="erp_status" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="">Estado ERP — todos</option>
                <option value="synced" <%= 'selected' if params[:erp_status] == 'synced' %>>Sincronizado</option>
                <option value="pending" <%= 'selected' if params[:erp_status] == 'pending' %>>Por sincronizar</option>
              </select>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <% if carteira_filter_params_hash.except(:sort, :direction).any? %>
    <div class="mb-3 d-flex align-items-center gap-2 flex-wrap">
      <small class="text-muted">Filtros activos:</small>
      <% if params[:query].present? %>
        <%= link_to bo_sales_rep_carteira_path(org_slug: current_organisation.slug, **carteira_filter_params_hash.except(:query, :page)), class: "badge bg-secondary text-decoration-none" do %>
          "<%= params[:query] %>" <i class="fa-solid fa-xmark ms-1"></i>
        <% end %>
      <% end %>
      <% if params[:status].present? %>
        <%
          status_label = {
            "active" => "Activo",
            "pending" => "Pendente convite",
            "not_invited" => "Sem login",
            "inactive" => "Inativo"
          }[params[:status]] || params[:status]
        %>
        <%= link_to bo_sales_rep_carteira_path(org_slug: current_organisation.slug, **carteira_filter_params_hash.except(:status, :page)), class: "badge bg-secondary text-decoration-none" do %>
          <%= status_label %> <i class="fa-solid fa-xmark ms-1"></i>
        <% end %>
      <% end %>
      <% if params[:erp_status].present? %>
        <% erp_label = params[:erp_status] == "synced" ? "ERP sincronizado" : "ERP por sincronizar" %>
        <%= link_to bo_sales_rep_carteira_path(org_slug: current_organisation.slug, **carteira_filter_params_hash.except(:erp_status, :page)), class: "badge bg-secondary text-decoration-none" do %>
          <%= erp_label %> <i class="fa-solid fa-xmark ms-1"></i>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% if @customers.empty? && carteira_filter_params_hash.except(:sort, :direction).empty? %>
    <div class="card">
      <div class="card-body text-center py-5">
        <i class="fa-solid fa-folder-open fa-3x text-muted mb-3"></i>
        <h5>Sem clientes atribuídos</h5>
        <p class="text-muted mb-3">
          Ainda não tens nenhum cliente na tua carteira. Podes criar um novo cliente diretamente
          ou pedir a um admin para te atribuir clientes existentes.
        </p>
        <%= link_to new_bo_customer_path(org_slug: current_organisation.slug), class: "btn btn-primary" do %>
          <i class="fa-solid fa-plus me-1"></i> Criar novo cliente
        <% end %>
      </div>
    </div>
  <% elsif @customers.empty? %>
    <div class="card">
      <div class="card-body text-center py-5">
        <i class="fa-solid fa-filter fa-2x text-muted mb-3"></i>
        <h6>Nenhum cliente corresponde aos filtros activos.</h6>
        <%= link_to "Limpar filtros", bo_sales_rep_carteira_path(org_slug: current_organisation.slug), class: "btn btn-sm btn-outline-secondary mt-2" %>
      </div>
    </div>
  <% else %>
    <div class="card">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>
                <%= link_to bo_sales_rep_carteira_path(org_slug: current_organisation.slug, **carteira_sort_link_params("contact_name")), class: "text-decoration-none text-dark" do %>
                  Cliente
                  <% if @sort_column == "contact_name" %>
                    <i class="fa-solid fa-sort-<%= @sort_direction == 'asc' ? 'up' : 'down' %> ms-1 small"></i>
                  <% end %>
                <% end %>
              </th>
              <th>
                <%= link_to bo_sales_rep_carteira_path(org_slug: current_organisation.slug, **carteira_sort_link_params("company_name")), class: "text-decoration-none text-dark" do %>
                  Empresa
                  <% if @sort_column == "company_name" %>
                    <i class="fa-solid fa-sort-<%= @sort_direction == 'asc' ? 'up' : 'down' %> ms-1 small"></i>
                  <% end %>
                <% end %>
              </th>
              <th>
                <%= link_to bo_sales_rep_carteira_path(org_slug: current_organisation.slug, **carteira_sort_link_params("last_order_at")), class: "text-decoration-none text-dark" do %>
                  Última encomenda
                  <% if @sort_column == "last_order_at" %>
                    <i class="fa-solid fa-sort-<%= @sort_direction == 'asc' ? 'up' : 'down' %> ms-1 small"></i>
                  <% end %>
                <% end %>
              </th>
              <% if erp_customer_sync_enabled? %>
                <th>Estado ERP</th>
              <% end %>
              <th class="text-end">Ações</th>
            </tr>
          </thead>
          <tbody>
            <% @customers.each do |customer| %>
              <tr class="carteira-row" data-href="<%= bo_customer_path(org_slug: current_organisation.slug, id: customer.id) %>" style="cursor: pointer;">
                <td>
                  <div class="fw-semibold">
                    <%= customer.contact_name %>
                    <% if @customer_ids_with_open_carts.include?(customer.id) %>
                      <span class="badge bg-info-subtle text-info ms-1" title="Tem um carrinho com itens por finalizar">
                        <i class="fa-solid fa-cart-shopping"></i> Carrinho aberto
                      </span>
                    <% end %>
                  </div>
                  <small class="text-muted"><%= customer.email %></small>
                </td>
                <td>
                  <div><%= customer.company_name %></div>
                  <% if customer.taxpayer_id.present? %>
                    <small class="text-muted">NIF <%= customer.taxpayer_id %></small>
                  <% end %>
                </td>
                <td>
                  <% if (date = @last_order_at[customer.id]) %>
                    <%= l(date, format: :short) %>
                    <small class="text-muted d-block"><%= time_ago_in_words(date) %> atrás</small>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>
                <% if erp_customer_sync_enabled? %>
                  <td>
                    <% if customer.external_id.present? %>
                      <span class="badge bg-success-subtle text-success">Sincronizado</span>
                    <% else %>
                      <span class="badge bg-warning text-dark">
                        <i class="fa-solid fa-rotate"></i> Por sincronizar
                      </span>
                    <% end %>
                  </td>
                <% end %>
                <td class="text-end" style="white-space: nowrap;" onclick="event.stopPropagation();">
                  <%= button_to bo_impersonation_path(org_slug: current_organisation.slug, customer_id: customer.id),
                                method: :post,
                                form: { class: "d-inline" },
                                class: "btn btn-sm btn-success",
                                data: { turbo_confirm: "Entrar no storefront como #{customer.company_name}?" } do %>
                    <i class="fa-solid fa-cart-shopping me-1"></i> Encomendar
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <% if @pagy.pages > 1 %>
        <div class="card-footer d-flex justify-content-center">
          <%== pagy_bootstrap_nav(@pagy) %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<%# Reused from BO dashboard — same expandable detail UX, same eager-loads. %>
<%= render "bo/dashboards/open_carts_modal", carts: @open_carts %>

<% end %>
