<%# locals: kpis (Hash com :total_customers + 4 invite counts), current_status (params[:status]) %>
<%
  tiles = [
    { key: :active_users,        icon: "fa-circle-check",         accent: "success",   status: "active" },
    { key: :pending_users,       icon: "fa-hourglass-half",       accent: "info",      status: "pending" },
    { key: :stale_pending_users, icon: "fa-triangle-exclamation", accent: "warning",   status: "stale_pending" },
    { key: :uninvited_users,     icon: "fa-envelope-open",        accent: "secondary", status: "not_invited" }
  ]
%>
<div class="d-flex flex-wrap align-items-center gap-2 mb-3">
  <span class="text-muted small me-2">
    <i class="fa-solid fa-users me-1"></i>
    <%= t('bo.dashboards.customer_health.total_customers', count: kpis[:total_customers]) %>
  </span>

  <% tiles.each do |tile| %>
    <% active = (current_status == tile[:status]) %>
    <%= link_to bo_sales_rep_carteira_path(org_slug: current_organisation.slug, status: tile[:status]),
                class: "btn btn-sm rounded-pill #{active ? "btn-#{tile[:accent]}" : "btn-light border"}" do %>
      <i class="fa-solid <%= tile[:icon] %> <%= "text-#{tile[:accent]}" unless active %> me-1"></i>
      <%= t("bo.dashboards.customer_health.#{tile[:key]}") %>
      <span class="badge bg-<%= active ? "light text-#{tile[:accent]}" : "#{tile[:accent]}-subtle text-#{tile[:accent]}" %> ms-1">
        <%= kpis[tile[:key]] %>
      </span>
    <% end %>
  <% end %>

  <% if current_status.present? %>
    <%= link_to bo_sales_rep_carteira_path(org_slug: current_organisation.slug),
                class: "btn btn-sm btn-link text-muted ms-1" do %>
      <i class="fa-solid fa-xmark me-1"></i> limpar
    <% end %>
  <% end %>
</div>
