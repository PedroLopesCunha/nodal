<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="utf-8">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    <%= render "bo/quick_access_tokens/pdf_styles", primary_color: @organisation.effective_primary_color || "#111" %>
    @page { size: A4; margin: 0; }
    html, body { width: 210mm; height: 297mm; margin: 0; padding: 0; }
    .sheet {
      display: grid;
      grid-template-columns: repeat(2, 85mm);
      grid-template-rows: repeat(5, 55mm);
      gap: 0;
      width: 170mm;
      height: 275mm;
      margin: 11mm auto;
    }
    .sheet .card {
      width: 85mm;
      height: 55mm;
      border: 0.15mm dashed #bbb;
    }
  </style>
</head>
<body>
  <div class="sheet">
    <% 10.times do %>
      <%= render "bo/business_cards/card_block",
                 organisation: @organisation,
                 qr_svg: @qr_svg %>
    <% end %>
  </div>
</body>
</html>
