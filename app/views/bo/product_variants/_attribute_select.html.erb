<div class="mb-3" data-controller="variant-attribute-select" data-variant-attribute-select-attribute-id-value="<%= attribute.id %>">
  <label class="form-label"><%= attribute.name %></label>
  <% field_name = local_assigns[:input_name] || "product_variant[attribute_value_ids][]" %>
  <% all_options = values.reject { |v| used_value_ids.include?(v.id) && !current_value_ids.include?(v.id) } %>
  <% selected = all_options.find { |v| current_value_ids.include?(v.id) } %>
  <input type="hidden" name="<%= field_name %>" value="<%= selected&.id %>" data-variant-attribute-select-target="hiddenInput">

  <div class="position-relative" data-variant-attribute-select-target="comboWrapper">
    <input type="text" class="form-control"
           placeholder="<%= t('bo.product_variants.form.select_option', attribute: attribute.name) %>"
           value="<%= selected&.value %>"
           data-variant-attribute-select-target="comboInput"
           data-action="input->variant-attribute-select#onType focus->variant-attribute-select#openDropdown keydown->variant-attribute-select#onKeydown"
           autocomplete="off">
    <ul class="dropdown-menu w-100 overflow-auto" style="max-height: 220px; display: none;" data-variant-attribute-select-target="dropdown">
      <% all_options.each do |value| %>
        <li>
          <a href="#" class="dropdown-item" data-id="<%= value.id %>" data-value="<%= value.value %>"
             data-action="click->variant-attribute-select#selectOption">
            <% if value.color_hex.present? %>
              <span class="d-inline-block rounded-circle me-1" style="width: 12px; height: 12px; background-color: <%= value.color_hex %>;"></span>
            <% end %>
            <%= value.value %>
          </a>
        </li>
      <% end %>
      <li data-variant-attribute-select-target="createItem" style="display: none;">
        <a href="#" class="dropdown-item text-success" data-action="click->variant-attribute-select#showCreateInput">
          <i class="fa-solid fa-plus me-1"></i>
          <span data-variant-attribute-select-target="createLabel"></span>
        </a>
      </li>
    </ul>
  </div>

  <div class="mt-2" style="display: none;" data-variant-attribute-select-target="inputWrapper">
    <div class="input-group">
      <input type="text" class="form-control form-control-sm"
             placeholder="<%= t('bo.product_variants.form.create_new_value') %>"
             data-variant-attribute-select-target="input"
             data-action="input->variant-attribute-select#onInput">
      <button type="button" class="btn btn-sm btn-outline-success"
              style="display: none;"
              data-variant-attribute-select-target="createBtn"
              data-action="click->variant-attribute-select#create">
        <i class="fa-solid fa-plus me-1"></i>
        <%= t('bo.product_variants.form.create_value') %>
        "<span data-variant-attribute-select-target="createName"></span>"
      </button>
    </div>
  </div>
</div>
