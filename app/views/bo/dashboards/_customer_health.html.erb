<%# locals: health (Hash from Dashboard::Metrics#customer_health), org_slug %>
<div class="card dashboard__card mb-3">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h6 class="mb-0">
      <i class="fa-solid fa-heart-pulse me-2 text-success"></i> <%= t('bo.dashboards.customer_health.title') %>
    </h6>
    <%= link_to bo_customers_path(org_slug: org_slug), class: "small text-muted text-decoration-none" do %>
      <%= t('bo.dashboards.customer_health.total_customers', count: health[:total_customers]) %>
      <i class="fa-solid fa-arrow-right ms-1"></i>
    <% end %>
  </div>
  <div class="card-body">
    <h3 class="h6 text-muted text-uppercase mb-2" style="font-size: 0.75rem; letter-spacing: 0.05em;">
      <%= t('bo.dashboards.customer_health.invitations') %>
    </h3>
    <div class="row g-3 mb-4">
    <%
      invite_tiles = [
        { key: :active_users,        icon: "fa-circle-check",        accent: "success",   status: "active" },
        { key: :pending_users,       icon: "fa-hourglass-half",      accent: "info",      status: "pending" },
        { key: :stale_pending_users, icon: "fa-triangle-exclamation", accent: "warning",  status: "stale_pending" },
        { key: :uninvited_users,     icon: "fa-envelope-open",       accent: "secondary", status: "not_invited" }
      ]
    %>
    <% invite_tiles.each do |tile| %>
      <div class="col-lg-3 col-md-6">
        <%= link_to bo_customers_path(org_slug: org_slug, status: tile[:status]),
                    class: "card text-decoration-none text-body border-0 shadow-sm h-100 customer-health-tile" do %>
          <div class="card-body">
            <div class="d-flex align-items-center gap-3">
              <div class="rounded-circle bg-<%= tile[:accent] %>-subtle text-<%= tile[:accent] %> d-flex align-items-center justify-content-center flex-shrink-0" style="width: 40px; height: 40px;">
                <i class="fa-solid <%= tile[:icon] %>"></i>
              </div>
              <div class="min-width-0">
                <div class="text-muted small d-flex align-items-center gap-1">
                  <%= t("bo.dashboards.customer_health.#{tile[:key]}") %>
                  <i class="fa-regular fa-circle-question text-muted" style="font-size: 0.75rem;"
                     title="<%= t("bo.dashboards.customer_health.#{tile[:key]}_hint") %>"></i>
                </div>
                <div class="fs-4 fw-bold"><%= health[tile[:key]] %></div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <h3 class="h6 text-muted text-uppercase mb-2" style="font-size: 0.75rem; letter-spacing: 0.05em;">
    <%= t('bo.dashboards.customer_health.footprint') %>
  </h3>
  <div class="row g-3">
    <%
      footprint_tiles = [
        { key: :online_now,         icon: "fa-bolt",       accent: "success", activity: "online_now" },
        { key: :active_week,        icon: "fa-user-check", accent: "primary", activity: "active_week" },
        { key: :accepted_no_return, icon: "fa-door-open",  accent: "secondary", activity: "accepted_no_return" },
        { key: :dormant,            icon: "fa-moon",       accent: "danger",  activity: "dormant" },
        { key: :engaged_no_orders,  icon: "fa-eye",        accent: "warning", activity: "engaged_no_orders" }
      ]
    %>
    <% footprint_tiles.each do |tile| %>
      <div class="col-lg col-md-4 col-sm-6">
        <%= link_to bo_customers_path(org_slug: org_slug, activity: tile[:activity]),
                    class: "card text-decoration-none text-body border-0 shadow-sm h-100 customer-health-tile" do %>
          <div class="card-body">
            <div class="d-flex align-items-center gap-3">
              <div class="rounded-circle bg-<%= tile[:accent] %>-subtle text-<%= tile[:accent] %> d-flex align-items-center justify-content-center flex-shrink-0" style="width: 40px; height: 40px;">
                <i class="fa-solid <%= tile[:icon] %>"></i>
              </div>
              <div class="min-width-0">
                <div class="text-muted small d-flex align-items-center gap-1">
                  <%= t("bo.dashboards.customer_health.#{tile[:key]}") %>
                  <i class="fa-regular fa-circle-question text-muted" style="font-size: 0.75rem;"
                     title="<%= t("bo.dashboards.customer_health.#{tile[:key]}_hint") %>"></i>
                </div>
                <div class="fs-4 fw-bold"><%= health[tile[:key]] %></div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
    </div>
  </div>
</div>
