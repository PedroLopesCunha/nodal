<% content_for :bo_main_content do%>

<div class="bo-page-header">
  <div class="d-flex justify-content-between align-items-center">
    <div>
      <h1><%= t('bo.homepage_settings.title') %></h1>
      <p class="text-muted mb-0"><%= t('bo.homepage_settings.subtitle') %></p>
    </div>
  </div>
</div>

<div class="bo-page-body">
  <%= render "bo/shared/settings_tabs" %>

<%# ==================== BANNERS ==================== %>
<div class="card mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5 class="card-title mb-0"><%= t('bo.homepage_settings.banners.title') %></h5>
      <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="collapse" data-bs-target="#newBannerForm">
        <i class="fa-solid fa-plus me-1"></i><%= t('bo.homepage_settings.banners.add') %>
      </button>
    </div>

    <%# New Banner Form (collapsed) %>
    <div class="collapse mb-3" id="newBannerForm">
      <div class="card card-body bg-light">
        <%= form_with url: create_banner_bo_homepage_settings_path(params[:org_slug]), method: :post, local: true do |f| %>
          <input type="hidden" name="homepage_banner[active]" value="true">
          <div class="row g-3">
            <div class="col-md-12">
              <label class="form-label"><%= t('bo.homepage_settings.banners.image') %> <span class="text-danger">*</span></label>
              <%= f.file_field :image, name: "homepage_banner[image]", class: "form-control", accept: "image/png,image/jpeg,image/webp", required: true %>
              <small class="text-muted"><%= t('bo.homepage_settings.banners.image_hint') %></small>
            </div>
            <div class="col-md-6">
              <label class="form-label"><%= t('bo.homepage_settings.banners.banner_title') %></label>
              <input type="text" name="homepage_banner[title]" class="form-control" placeholder="<%= t('bo.homepage_settings.banners.title_placeholder') %>">
            </div>
            <div class="col-md-6">
              <label class="form-label"><%= t('bo.homepage_settings.banners.banner_subtitle') %></label>
              <input type="text" name="homepage_banner[subtitle]" class="form-control" placeholder="<%= t('bo.homepage_settings.banners.subtitle_placeholder') %>">
            </div>
            <div class="col-md-8">
              <label class="form-label"><%= t('bo.homepage_settings.banners.link_url') %></label>
              <input type="text" name="homepage_banner[link_url]" class="form-control" placeholder="<%= t('bo.homepage_settings.banners.link_url_placeholder') %>">
            </div>
            <div class="col-md-2">
              <label class="form-label"><%= t('bo.homepage_settings.banners.link_text') %></label>
              <input type="text" name="homepage_banner[link_text]" class="form-control" placeholder="<%= t('bo.homepage_settings.banners.link_text_placeholder') %>">
            </div>
            <div class="col-md-2">
              <label class="form-label"><%= t('bo.homepage_settings.banners.text_theme') %></label>
              <select name="homepage_banner[text_theme]" class="form-select">
                <option value="light"><%= t('bo.homepage_settings.banners.theme_light') %></option>
                <option value="dark"><%= t('bo.homepage_settings.banners.theme_dark') %></option>
              </select>
            </div>
          </div>
          <div class="mt-3">
            <button type="submit" class="btn btn-primary btn-sm"><%= t('bo.homepage_settings.banners.save') %></button>
            <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="collapse" data-bs-target="#newBannerForm"><%= t('bo.common.actions.cancel') %></button>
          </div>
        <% end %>
      </div>
    </div>

    <%# Existing Banners %>
    <% if @banners.any? %>
      <div class="row g-3">
        <% @banners.each do |banner| %>
          <div class="col-md-6">
            <div class="card h-100 <%= 'border-success' if banner.active? %> <%= 'opacity-50' unless banner.active? %>">
              <% if banner.image.attached? %>
                <%= image_tag banner.image, class: "card-img-top", style: "height: 160px; object-fit: cover;" %>
              <% end %>
              <div class="card-body p-3">
                <% if banner.title.present? %>
                  <h6 class="card-title mb-1"><%= banner.title %></h6>
                <% end %>
                <% if banner.subtitle.present? %>
                  <p class="text-muted mb-2 small"><%= banner.subtitle %></p>
                <% end %>
                <% if banner.link_url.present? %>
                  <p class="mb-2" style="font-size: 0.75rem;">
                    <i class="fa-solid fa-link me-1 text-muted"></i>
                    <span class="text-muted"><%= truncate(banner.link_url, length: 40) %></span>
                    <% if banner.link_text.present? %>
                      &middot; <span class="fw-semibold"><%= banner.link_text %></span>
                    <% end %>
                  </p>
                <% end %>
                <div class="d-flex justify-content-between align-items-center">
                  <%= button_to toggle_banner_bo_homepage_settings_path(params[:org_slug], banner_id: banner.id),
                      method: :patch,
                      data: { turbo: false },
                      class: "btn btn-sm #{banner.active? ? 'btn-success' : 'btn-outline-secondary'}" do %>
                    <i class="fa-solid fa-<%= banner.active? ? 'eye' : 'eye-slash' %> me-1"></i>
                    <%= banner.active? ? t('bo.common.statuses.active') : t('bo.common.statuses.inactive') %>
                  <% end %>
                  <div class="d-flex gap-1">
                    <button type="button" class="btn btn-outline-primary btn-sm" data-bs-toggle="collapse" data-bs-target="#editBanner<%= banner.id %>">
                      <i class="fa-solid fa-pen" style="font-size: 0.7rem;"></i>
                    </button>
                    <%= button_to destroy_banner_bo_homepage_settings_path(params[:org_slug], banner_id: banner.id),
                        method: :delete,
                        class: "btn btn-outline-danger btn-sm",
                        data: { turbo_confirm: t('bo.common.confirm_delete') } do %>
                      <i class="fa-solid fa-trash" style="font-size: 0.7rem;"></i>
                    <% end %>
                  </div>
                </div>
              </div>
              <%# Inline Edit Form %>
              <div class="collapse" id="editBanner<%= banner.id %>">
                <div class="card-footer bg-light p-3">
                  <%= form_with url: update_banner_bo_homepage_settings_path(params[:org_slug], banner_id: banner.id), method: :patch, local: true do %>
                    <div class="row g-2">
                      <div class="col-12">
                        <label class="form-label small"><%= t('bo.homepage_settings.banners.image') %></label>
                        <input type="file" name="homepage_banner[image]" class="form-control form-control-sm" accept="image/png,image/jpeg,image/webp">
                      </div>
                      <div class="col-6">
                        <label class="form-label small"><%= t('bo.homepage_settings.banners.banner_title') %></label>
                        <input type="text" name="homepage_banner[title]" class="form-control form-control-sm" value="<%= banner.title %>">
                      </div>
                      <div class="col-6">
                        <label class="form-label small"><%= t('bo.homepage_settings.banners.banner_subtitle') %></label>
                        <input type="text" name="homepage_banner[subtitle]" class="form-control form-control-sm" value="<%= banner.subtitle %>">
                      </div>
                      <div class="col-8">
                        <label class="form-label small"><%= t('bo.homepage_settings.banners.link_url') %></label>
                        <input type="text" name="homepage_banner[link_url]" class="form-control form-control-sm" value="<%= banner.link_url %>">
                      </div>
                      <div class="col-4">
                        <label class="form-label small"><%= t('bo.homepage_settings.banners.link_text') %></label>
                        <input type="text" name="homepage_banner[link_text]" class="form-control form-control-sm" value="<%= banner.link_text %>">
                      </div>
                      <div class="col-4">
                        <label class="form-label small"><%= t('bo.homepage_settings.banners.text_theme') %></label>
                        <select name="homepage_banner[text_theme]" class="form-select form-select-sm">
                          <option value="light" <%= 'selected' if banner.text_theme == 'light' %>><%= t('bo.homepage_settings.banners.theme_light') %></option>
                          <option value="dark" <%= 'selected' if banner.text_theme == 'dark' %>><%= t('bo.homepage_settings.banners.theme_dark') %></option>
                        </select>
                      </div>
                    </div>
                    <div class="mt-2">
                      <button type="submit" class="btn btn-primary btn-sm"><%= t('bo.homepage_settings.banners.save') %></button>
                      <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="collapse" data-bs-target="#editBanner<%= banner.id %>"><%= t('bo.common.actions.cancel') %></button>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-4">
        <i class="fa-solid fa-images fa-2x text-muted mb-2"></i>
        <p class="text-muted mb-0"><%= t('bo.homepage_settings.banners.empty') %></p>
      </div>
    <% end %>
  </div>
</div>

<%# ==================== FEATURED CATEGORIES ==================== %>
<div class="card mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5 class="card-title mb-0"><%= t('bo.homepage_settings.featured_categories.title') %></h5>
      <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#addCategoriesModal">
        <i class="fa-solid fa-plus me-1"></i><%= t('bo.homepage_settings.featured_categories.add') %>
      </button>
    </div>

    <% if @featured_categories.any? %>
      <div class="list-group">
        <% @featured_categories.each do |fc| %>
          <div class="list-group-item d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
              <% if fc.category.photo.attached? %>
                <%= image_tag fc.category.photo, style: "width: 40px; height: 40px; object-fit: cover;", class: "rounded" %>
              <% else %>
                <div class="rounded d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background: <%= fc.category.color.presence || '#6c757d' %>;">
                  <span class="text-white small fw-bold"><%= fc.category.name.first.upcase %></span>
                </div>
              <% end %>
              <div>
                <div class="fw-semibold small"><%= fc.category.name %></div>
                <div class="text-muted" style="font-size: 0.75rem;"><%= t('bo.homepage_settings.featured_categories.products_count', count: fc.category.all_products_count) %></div>
              </div>
            </div>
            <div class="d-flex gap-1">
              <%= link_to edit_bo_category_path(params[:org_slug], fc.category), class: "btn btn-outline-secondary btn-sm", title: t('bo.common.actions.edit') do %>
                <i class="fa-solid fa-pen" style="font-size: 0.7rem;"></i>
              <% end %>
              <%= button_to remove_featured_category_bo_homepage_settings_path(params[:org_slug], category_id: fc.category_id),
                method: :delete,
                class: "btn btn-outline-danger btn-sm" do %>
                <i class="fa-solid fa-times"></i>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-4">
        <i class="fa-solid fa-folder-open fa-2x text-muted mb-2"></i>
        <p class="text-muted mb-0"><%= t('bo.homepage_settings.featured_categories.empty') %></p>
      </div>
    <% end %>
  </div>
</div>

<%# ==================== FEATURED PRODUCTS ==================== %>
<div class="card mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5 class="card-title mb-0"><%= t('bo.homepage_settings.featured_products.title') %></h5>
      <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#addProductsModal">
        <i class="fa-solid fa-plus me-1"></i><%= t('bo.homepage_settings.featured_products.add') %>
      </button>
    </div>

    <% if @featured_products.any? %>
      <div class="list-group">
        <% @featured_products.each do |fp| %>
          <div class="list-group-item d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
              <% if fp.product.photo_attached? %>
                <%= image_tag fp.product.photo, style: "width: 40px; height: 40px; object-fit: cover;", class: "rounded" %>
              <% else %>
                <div class="rounded d-flex align-items-center justify-content-center bg-light" style="width: 40px; height: 40px;">
                  <i class="fa-solid fa-image text-muted" style="font-size: 0.8rem;"></i>
                </div>
              <% end %>
              <div>
                <div class="fw-semibold small"><%= fp.product.name %></div>
                <div class="text-muted" style="font-size: 0.75rem;"><%= fp.product.sku %></div>
              </div>
            </div>
            <div class="d-flex gap-1">
              <%= link_to edit_bo_product_path(params[:org_slug], fp.product), class: "btn btn-outline-secondary btn-sm", title: t('bo.common.actions.edit') do %>
                <i class="fa-solid fa-pen" style="font-size: 0.7rem;"></i>
              <% end %>
              <%= button_to remove_featured_product_bo_homepage_settings_path(params[:org_slug], product_id: fp.product_id),
                  method: :delete,
                  class: "btn btn-outline-danger btn-sm" do %>
                <i class="fa-solid fa-times"></i>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-4">
        <i class="fa-solid fa-star fa-2x text-muted mb-2"></i>
        <p class="text-muted mb-0"><%= t('bo.homepage_settings.featured_products.empty') %></p>
      </div>
    <% end %>
  </div>
</div>

<%# ==================== MODALS ==================== %>

<%# Add Categories Modal %>
<div class="modal fade" id="addCategoriesModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <%= form_with url: add_featured_categories_bo_homepage_settings_path(params[:org_slug]), method: :post, local: true do %>
        <div class="modal-header">
          <h5 class="modal-title"><%= t('bo.homepage_settings.featured_categories.modal_title') %></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <% existing_category_ids = @featured_categories.map(&:category_id) %>
          <% available_categories = current_organisation.categories.kept.where.not(id: existing_category_ids).order(:name) %>
          <% if available_categories.any? %>
            <div class="mb-3">
              <input type="text" class="form-control" placeholder="<%= t('bo.homepage_settings.search') %>"
                     oninput="var q=this.value.toLowerCase(); this.closest('.modal-body').querySelectorAll('.category-item').forEach(function(el){ var n=el.getAttribute('data-name')||''; el.style.setProperty('display', n.indexOf(q)>=0?'flex':'none', 'important'); })">
            </div>
            <div class="list-group" style="max-height: 400px; overflow-y: auto;">
              <% available_categories.each do |category| %>
                <label class="list-group-item list-group-item-action d-flex align-items-center category-item" data-name="<%= category.name.downcase %>">
                  <input type="checkbox" name="category_ids[]" value="<%= category.id %>" class="form-check-input me-3">
                  <div class="d-flex align-items-center gap-2 flex-grow-1">
                    <div class="rounded d-flex align-items-center justify-content-center flex-shrink-0" style="width: 32px; height: 32px; background: <%= category.color.presence || '#6c757d' %>;">
                      <span class="text-white small fw-bold"><%= category.name.first.upcase %></span>
                    </div>
                    <div class="flex-grow-1">
                      <div class="fw-semibold"><%= category.name %></div>
                      <% if category.ancestors.any? %>
                        <small class="text-muted"><%= category.ancestors.map(&:name).join(' > ') %></small>
                      <% end %>
                    </div>
                    <span class="badge bg-light text-muted"><%= category.all_products_count %></span>
                  </div>
                </label>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-4">
              <i class="fa-solid fa-check-circle fa-2x text-success mb-2"></i>
              <p class="text-muted mb-0"><%= t('bo.homepage_settings.featured_categories.all_added') %></p>
            </div>
          <% end %>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"><%= t('bo.common.actions.cancel') %></button>
          <% if available_categories.any? %>
            <button type="submit" class="btn btn-primary"><%= t('bo.homepage_settings.featured_categories.add_selected') %></button>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# Add Products Modal %>
<div class="modal fade" id="addProductsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <%= form_with url: add_featured_products_bo_homepage_settings_path(params[:org_slug]), method: :post, local: true do %>
        <div class="modal-header">
          <h5 class="modal-title"><%= t('bo.homepage_settings.featured_products.modal_title') %></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <% existing_product_ids = @featured_products.map(&:product_id) %>
          <% available_products = current_organisation.products.where.not(id: existing_product_ids).where(available: true).order(:name) %>
          <% if available_products.any? %>
            <div class="mb-3">
              <input type="text" class="form-control" placeholder="<%= t('bo.homepage_settings.search') %>"
                     oninput="var q=this.value.toLowerCase(); this.closest('.modal-body').querySelectorAll('.product-item').forEach(function(el){ var n=el.getAttribute('data-name')||''; var s=el.getAttribute('data-sku')||''; el.style.setProperty('display', (n.indexOf(q)>=0||s.indexOf(q)>=0)?'flex':'none', 'important'); })">
            </div>
            <div class="list-group" style="max-height: 400px; overflow-y: auto;">
              <% available_products.each do |product| %>
                <label class="list-group-item list-group-item-action d-flex align-items-center product-item" data-name="<%= product.name.downcase %>" data-sku="<%= product.sku&.downcase %>">
                  <input type="checkbox" name="product_ids[]" value="<%= product.id %>" class="form-check-input me-3">
                  <div class="flex-grow-1">
                    <div class="fw-semibold"><%= product.name %></div>
                    <small class="text-muted"><%= product.sku %> &middot; <%= humanized_money_with_symbol(product.price) %></small>
                  </div>
                </label>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-4">
              <i class="fa-solid fa-check-circle fa-2x text-success mb-2"></i>
              <p class="text-muted mb-0"><%= t('bo.homepage_settings.featured_products.all_added') %></p>
            </div>
          <% end %>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"><%= t('bo.common.actions.cancel') %></button>
          <% if available_products.any? %>
            <button type="submit" class="btn btn-primary"><%= t('bo.homepage_settings.featured_products.add_selected') %></button>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

</div> <%# bo-page-body %>

<% end %>
