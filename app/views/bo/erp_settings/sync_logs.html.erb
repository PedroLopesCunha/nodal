<% content_for :bo_main_content do %>

<div class="bo-page-header">
  <div class="d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center gap-3">
      <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white fw-bold" style="width: 60px; height: 60px; font-size: 1.25rem;">
        <i class="fa-solid fa-list"></i>
      </div>

      <div>
        <h1>Sync Logs</h1>
        <span class="text-muted">ERP Integration History</span>
      </div>
    </div>

    <div class="bo-page-actions">
      <%= link_to edit_bo_erp_settings_path, class: "btn btn-outline-secondary" do %>
        <i class="fa-solid fa-arrow-left fa-lg"></i> Back to ERP Settings
      <% end %>
    </div>
  </div>
</div>

<div class="bo-page-body">

<div class="card">
  <div class="card-body">
    <% if @sync_logs.any? %>
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Type</th>
              <th>Entity</th>
              <th>Status</th>
              <th>Duration</th>
              <th>Created</th>
              <th>Updated</th>
              <th>Failed</th>
              <th>Summary</th>
            </tr>
          </thead>
          <tbody>
            <% @sync_logs.each do |log| %>
            <tr>
              <td><%= log.created_at.strftime("%b %d, %Y %H:%M") %></td>
              <td><span class="badge bg-secondary"><%= log.sync_type.capitalize %></span></td>
              <td><%= log.entity_type.capitalize %></td>
              <td>
                <% case log.status %>
                <% when 'completed' %>
                  <span class="badge bg-success">Completed</span>
                <% when 'failed' %>
                  <span class="badge bg-danger">Failed</span>
                <% when 'running' %>
                  <span class="badge bg-warning">Running</span>
                <% end %>
              </td>
              <td><%= log.duration_in_words || '-' %></td>
              <td class="text-success"><%= log.records_created %></td>
              <td class="text-primary"><%= log.records_updated %></td>
              <td class="text-danger"><%= log.records_failed %></td>
              <td>
                <% if log.summary.present? %>
                  <small class="text-muted"><%= truncate(log.summary, length: 50) %></small>
                <% else %>
                  -
                <% end %>
              </td>
            </tr>
            <% if log.error_details.present? && log.error_details.any? %>
            <tr>
              <td colspan="9" class="bg-light">
                <details>
                  <summary class="text-danger small"><i class="fa-solid fa-circle-exclamation me-1"></i>View <%= log.error_details.size %> error(s)</summary>
                  <ul class="list-unstyled mt-2 mb-0 small">
                    <% log.error_details.first(5).each do |error| %>
                      <li class="text-danger">
                        <strong><%= error['record'] %>:</strong> <%= error['error'] %>
                      </li>
                    <% end %>
                    <% if log.error_details.size > 5 %>
                      <li class="text-muted">... and <%= log.error_details.size - 5 %> more</li>
                    <% end %>
                  </ul>
                </details>
              </td>
            </tr>
            <% end %>
            <% if log.change_details.present? && log.change_details.any? %>
            <tr>
              <td colspan="9" class="bg-light">
                <details>
                  <summary class="text-primary small"><i class="fa-solid fa-pen-to-square me-1"></i>View <%= log.change_details.size %> change(s)</summary>
                  <div class="mt-2 small">
                    <% created = log.change_details.select { |c| c['action'] == 'created' } %>
                    <% updated = log.change_details.select { |c| c['action'] == 'updated' } %>
                    <% stock_updated = log.change_details.select { |c| c['action'] == 'stock_updated' } %>

                    <% if created.any? %>
                      <p class="mb-1 fw-bold text-success"><i class="fa-solid fa-plus me-1"></i>Created (<%= created.size %>)</p>
                      <ul class="list-unstyled mb-2 ms-3">
                        <% created.first(10).each do |change| %>
                          <li class="text-success">
                            <strong><%= change['external_id'] %></strong>
                            (<%= change['record_type'] %>)
                            <% if change['changes'].present? %>
                              — <%= change.dig('changes', 'name') || change.dig('changes', 'sku') %>
                            <% end %>
                          </li>
                        <% end %>
                        <% if created.size > 10 %>
                          <li class="text-muted">... and <%= created.size - 10 %> more</li>
                        <% end %>
                      </ul>
                    <% end %>

                    <% if updated.any? %>
                      <p class="mb-1 fw-bold text-primary"><i class="fa-solid fa-arrows-rotate me-1"></i>Updated (<%= updated.size %>)</p>
                      <ul class="list-unstyled mb-2 ms-3">
                        <% updated.first(10).each do |change| %>
                          <li>
                            <strong><%= change['external_id'] %></strong>
                            (<%= change['record_type'] %>)
                            <% if change['changes'].present? %>
                              <ul class="list-unstyled ms-3">
                                <% change['changes'].each do |field, values| %>
                                  <li class="text-muted">
                                    <%= field %>: <span class="text-danger"><%= values[0] %></span> &rarr; <span class="text-success"><%= values[1] %></span>
                                  </li>
                                <% end %>
                              </ul>
                            <% end %>
                          </li>
                        <% end %>
                        <% if updated.size > 10 %>
                          <li class="text-muted">... and <%= updated.size - 10 %> more</li>
                        <% end %>
                      </ul>
                    <% end %>

                    <% if stock_updated.any? %>
                      <p class="mb-1 fw-bold text-secondary"><i class="fa-solid fa-boxes-stacked me-1"></i>Stock Updated (<%= stock_updated.size %>)</p>
                      <ul class="list-unstyled mb-0 ms-3">
                        <% stock_updated.first(10).each do |change| %>
                          <li class="text-muted">
                            <strong><%= change['external_id'] %></strong>
                            <% if change.dig('changes', 'stock_quantity') %>
                              — <%= change['changes']['stock_quantity'][0] %> &rarr; <%= change['changes']['stock_quantity'][1] %>
                            <% end %>
                          </li>
                        <% end %>
                        <% if stock_updated.size > 10 %>
                          <li class="text-muted">... and <%= stock_updated.size - 10 %> more</li>
                        <% end %>
                      </ul>
                    <% end %>
                  </div>
                </details>
              </td>
            </tr>
            <% end %>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @sync_logs.respond_to?(:total_pages) && @sync_logs.total_pages > 1 %>
        <nav class="mt-4">
          <%= paginate @sync_logs %>
        </nav>
      <% end %>
    <% else %>
      <div class="text-center py-5">
        <i class="fa-solid fa-inbox text-muted" style="font-size: 3rem;"></i>
        <p class="text-muted mt-3">No sync logs yet. Run your first sync to see activity here.</p>
        <%= link_to edit_bo_erp_settings_path, class: "btn btn-primary" do %>
          Configure ERP Integration
        <% end %>
      </div>
    <% end %>
  </div>
</div>

</div>

<% end %>
