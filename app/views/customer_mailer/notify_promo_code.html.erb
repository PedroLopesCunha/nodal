<!-- Promo Code banner -->
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin: 0 0 32px 0;">
  <tr>
    <td style="background: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%); background-color: #7c3aed; border-radius: 12px; padding: 24px; text-align: center;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" align="center">
        <tr>
          <td style="background-color: rgba(255,255,255,0.2); border-radius: 50%; width: 48px; height: 48px; text-align: center; vertical-align: middle;">
            <span style="font-size: 24px; line-height: 48px;">🎟️</span>
          </td>
        </tr>
      </table>
      <h1 style="margin: 16px 0 0 0; font-size: 24px; font-weight: 700; color: #ffffff;">
        <%= t('mailers.customer_mailer.promo_code.banner_title') %>
      </h1>
    </td>
  </tr>
</table>

<p style="margin: 0 0 8px 0; font-size: 16px;"><%= t('mailers.customer_mailer.promo_code.greeting') %></p>

<p style="margin: 0 0 24px 0; color: #4b5563;">
  <%= t('mailers.customer_mailer.promo_code.intro') %>
</p>

<!-- Shop button -->
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin: 0 0 32px 0;">
  <tr>
    <td align="center">
      <a href="<%= products_url(org_slug: @organisation.slug) %>" style="display: inline-block; background: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%); background-color: #7c3aed; color: #ffffff; text-decoration: none; font-size: 16px; font-weight: 600; padding: 14px 32px; border-radius: 8px;">
        <%= t('mailers.common.shop_now') %>
      </a>
    </td>
  </tr>
</table>

<!-- Promo code card -->
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin: 0 0 32px 0; border: 1px solid #e5e5e5; border-radius: 12px; overflow: hidden;">
  <!-- Card header -->
  <tr>
    <td style="padding: 16px 20px; background-color: #f9fafb; border-bottom: 1px solid #e5e5e5;">
      <span style="font-size: 14px; font-weight: 600; color: #1a1a1a; text-transform: uppercase; letter-spacing: 0.5px;"><%= t('mailers.customer_mailer.promo_code.promo_details') %></span>
    </td>
  </tr>
  <!-- Info -->
  <tr>
    <td style="padding: 20px;">
      <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
        <tr>
          <td style="vertical-align: top;">
            <!-- Promo code display -->
            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin: 0 0 20px 0;">
              <tr>
                <td style="background-color: #f3f4f6; padding: 16px 24px; border-radius: 12px; text-align: center; border: 2px dashed #9ca3af;">
                  <span style="font-size: 12px; color: #9ca3af; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 8px;"><%= t('mailers.customer_mailer.promo_code.your_code') %></span>
                  <span style="font-size: 32px; font-weight: 700; color: #1a1a1a; letter-spacing: 3px;"><%= @promo_code.code %></span>
                </td>
              </tr>
            </table>

            <!-- Discount badge -->
            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin: 0 0 20px 0;">
              <tr>
                <td style="background-color: #fef3c7; padding: 16px 24px; border-radius: 12px; text-align: center;">
                  <span style="font-size: 28px; font-weight: 700; color: #92400e;">
                    <%= @promo_code.value_display %> <%= t('mailers.common.off') %>
                  </span>
                  <p style="margin: 4px 0 0 0; font-size: 14px; color: #92400e;"><%= t('mailers.customer_mailer.promo_code.on_your_order') %></p>
                </td>
              </tr>
            </table>

            <!-- Details -->
            <table role="presentation" cellspacing="0" cellpadding="0" border="0">
              <tr>
                <% if @promo_code.min_order_amount_cents.present? && @promo_code.min_order_amount_cents > 0 %>
                  <td style="padding-right: 32px;">
                    <span style="font-size: 12px; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.5px;"><%= t('mailers.common.min_order') %></span>
                    <p style="margin: 4px 0 0 0; font-size: 18px; font-weight: 600; color: #1a1a1a;"><%= @promo_code.min_order_amount.format %></p>
                  </td>
                <% end %>
                <td>
                  <span style="font-size: 12px; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.5px;"><%= t('mailers.common.valid') %></span>
                  <p style="margin: 4px 0 0 0; font-size: 18px; font-weight: 600; color: #1a1a1a;"><%= @promo_code.valid_period_display %></p>
                </td>
              </tr>
            </table>

            <% if @promo_code.description.present? %>
              <p style="margin: 16px 0 0 0; font-size: 14px; color: #6b7177; line-height: 1.5;"><%= @promo_code.description %></p>
            <% end %>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<!-- CTA section -->
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin: 0 0 24px 0;">
  <tr>
    <td style="padding: 20px; background-color: #f0fdf4; border-radius: 12px; border-left: 4px solid <%= @organisation.effective_primary_color %>;">
      <p style="margin: 0 0 8px 0; font-size: 14px; font-weight: 600; color: #166534;"><%= t('mailers.common.dont_miss_out') %></p>
      <p style="margin: 0; font-size: 14px; color: #4b5563; line-height: 1.5;">
        <%= t('mailers.customer_mailer.promo_code.use_code_cta', code: @promo_code.code) %>
      </p>
    </td>
  </tr>
</table>

<p style="margin: 0; color: #9ca3af; font-size: 13px; text-align: center;">
  <%= t('mailers.common.questions_footer') %>
</p>
