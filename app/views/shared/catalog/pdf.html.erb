<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; font-size: 12px; color: #333; line-height: 1.4; }

    /* Cover page */
    .cover { page-break-after: always; display: flex; flex-direction: column; justify-content: center; align-items: center; height: 100vh; text-align: center; }
    .cover-logo { max-width: 200px; max-height: 120px; margin-bottom: 40px; }
    .cover h1 { font-size: 36px; font-weight: 700; margin-bottom: 12px; color: #222; }
    .cover .cover-date { font-size: 16px; color: #888; }
    .cover .cover-count { font-size: 14px; color: #aaa; margin-top: 8px; }

    /* Category headers */
    .category-header { page-break-before: always; padding: 20px 0 10px; border-bottom: 2px solid #333; margin-bottom: 20px; }
    .category-header:first-of-type { page-break-before: auto; }
    .category-header h2 { font-size: 20px; font-weight: 700; color: #222; }

    /* Grid layout */
    .product-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 20px; }
    .product-card { border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden; page-break-inside: avoid; }
    .product-card-img { width: 100%; height: 160px; object-fit: cover; display: block; background: #f5f5f5; }
    .product-card-placeholder { width: 100%; height: 160px; background: #f0f0f0; display: flex; align-items: center; justify-content: center; color: #ccc; font-size: 36px; }
    .product-card-body { padding: 10px 12px; }
    .product-card-name { font-weight: 600; font-size: 13px; margin-bottom: 2px; color: #222; }
    .product-card-sku { font-size: 10px; color: #999; margin-bottom: 4px; }
    .product-card-description { font-size: 10px; color: #666; margin-bottom: 6px; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .product-card-price { font-weight: 700; font-size: 14px; color: #222; }
    .product-card-price-request { font-size: 11px; color: #888; font-style: italic; }
    .product-card-variants { font-size: 10px; color: #555; margin-top: 4px; padding-top: 4px; border-top: 1px solid #eee; }
    .product-card-variants span { display: inline-block; background: #f0f0f0; padding: 1px 6px; border-radius: 3px; margin: 1px 2px 1px 0; }

    /* List layout */
    .product-list { margin-bottom: 10px; }
    .product-list-item { display: flex; gap: 15px; padding: 12px 0; border-bottom: 1px solid #eee; page-break-inside: avoid; }
    .product-list-img { width: 80px; height: 80px; object-fit: cover; border-radius: 6px; flex-shrink: 0; background: #f5f5f5; }
    .product-list-placeholder { width: 80px; height: 80px; background: #f0f0f0; border-radius: 6px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; color: #ccc; font-size: 24px; }
    .product-list-info { flex: 1; }
    .product-list-name { font-weight: 600; font-size: 14px; color: #222; margin-bottom: 2px; }
    .product-list-sku { font-size: 10px; color: #999; margin-bottom: 4px; }
    .product-list-description { font-size: 11px; color: #666; line-height: 1.3; margin-bottom: 4px; }
    .product-list-price { font-weight: 700; font-size: 15px; color: #222; text-align: right; white-space: nowrap; }
    .product-list-variants { font-size: 10px; color: #555; margin-top: 4px; }
    .product-list-variants span { display: inline-block; background: #f0f0f0; padding: 1px 6px; border-radius: 3px; margin: 1px 2px 1px 0; }

    /* Variant details - grid */
    .product-card-variants-detail { margin-top: 6px; padding-top: 6px; border-top: 1px solid #eee; }
    .variant-row { display: flex; align-items: center; gap: 6px; padding: 2px 0; font-size: 10px; }
    .variant-thumb { width: 24px; height: 24px; border-radius: 3px; object-fit: cover; flex-shrink: 0; }
    .variant-options { flex: 1; color: #444; }
    .variant-sku { color: #999; font-size: 9px; }
    .variant-price { font-weight: 600; color: #222; white-space: nowrap; }

    /* Variant details - list */
    .variant-table { width: 100%; border-collapse: collapse; margin-top: 6px; font-size: 10px; }
    .variant-table th { font-size: 9px; text-transform: uppercase; color: #999; font-weight: 500; padding: 3px 6px; border-bottom: 1px solid #eee; }
    .variant-table td { padding: 3px 6px; border-bottom: 1px solid #f5f5f5; vertical-align: middle; }
    .variant-table .variant-thumb { width: 28px; height: 28px; border-radius: 4px; }

    /* Footer */
    .page-footer { position: fixed; bottom: 0; left: 0; right: 0; text-align: center; font-size: 9px; color: #bbb; padding: 10px; }
  </style>
</head>
<body>
  <%# Cover Page %>
  <div class="cover">
    <% if @organisation.logo.attached? %>
      <%= image_tag url_for(@organisation.logo), class: "cover-logo" %>
    <% end %>
    <h1><%= @catalog_title %></h1>
    <div class="cover-date"><%= l(Date.today, format: :long) %></div>
    <div class="cover-count"><%= t('bo.catalog.pdf.product_count', count: @products.size) %></div>
  </div>

  <%# Product Pages %>
  <% if @group_by_category %>
    <%
      # Group products by their primary category
      grouped = @products.group_by { |p| p.primary_category&.name || t('bo.catalog.pdf.uncategorized') }
      grouped = grouped.sort_by { |cat_name, _| cat_name }
    %>
    <% grouped.each do |category_name, products| %>
      <div class="category-header">
        <h2><%= category_name %></h2>
      </div>
      <% if @layout == "grid" %>
        <div class="product-grid">
          <% products.each do |product| %>
            <%= render partial: "shared/catalog/product_grid", locals: { product: product, show_prices: @show_prices, show_sku: @show_sku, show_description: @show_description, show_variants: @show_variants, show_variant_sku: @show_variant_sku, show_variant_price: @show_variant_price, show_variant_photo: @show_variant_photo } %>
          <% end %>
        </div>
      <% else %>
        <div class="product-list">
          <% products.each do |product| %>
            <%= render partial: "shared/catalog/product_list", locals: { product: product, show_prices: @show_prices, show_sku: @show_sku, show_description: @show_description, show_variants: @show_variants, show_variant_sku: @show_variant_sku, show_variant_price: @show_variant_price, show_variant_photo: @show_variant_photo } %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <% if @layout == "grid" %>
      <div class="product-grid">
        <% @products.each do |product| %>
          <%= render partial: "shared/catalog/product_grid", locals: { product: product, show_prices: @show_prices, show_sku: @show_sku, show_description: @show_description, show_variants: @show_variants, show_variant_sku: @show_variant_sku, show_variant_price: @show_variant_price, show_variant_photo: @show_variant_photo } %>
        <% end %>
      </div>
    <% else %>
      <div class="product-list">
        <% @products.each do |product| %>
          <%= render partial: "shared/catalog/product_list", locals: { product: product, show_prices: @show_prices, show_sku: @show_sku, show_description: @show_description, show_variants: @show_variants, show_variant_sku: @show_variant_sku, show_variant_price: @show_variant_price, show_variant_photo: @show_variant_photo } %>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <div class="page-footer">
    <%= @organisation.name %> &mdash; <%= l(Date.today, format: :long) %>
  </div>
</body>
</html>
