<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; font-size: 13px; color: #333; line-height: 1.5; }

    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 2px solid #333; }
    .header h1 { font-size: 22px; margin-bottom: 4px; }
    .header .subtitle { color: #666; font-size: 13px; }
    .header .org-name { font-size: 16px; font-weight: 600; text-align: right; }
    .header .org-details { color: #666; font-size: 12px; text-align: right; }

    .info-grid { display: flex; gap: 30px; margin-bottom: 25px; }
    .info-block { flex: 1; }
    .info-block h3 { font-size: 11px; text-transform: uppercase; color: #888; letter-spacing: 0.5px; margin-bottom: 6px; }
    .info-block p { margin: 0; }

    .badge { display: inline-block; padding: 3px 10px; border-radius: 4px; font-size: 11px; font-weight: 600; }
    .badge-success { background: #d1e7dd; color: #0f5132; }
    .badge-warning { background: #fff3cd; color: #664d03; }
    .badge-info { background: #cff4fc; color: #055160; }
    .badge-secondary { background: #e2e3e5; color: #41464b; }
    .badge-danger { background: #f8d7da; color: #842029; }

    table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
    thead th { background: #f8f9fa; padding: 10px 8px; text-align: left; font-size: 11px; text-transform: uppercase; color: #666; letter-spacing: 0.3px; border-bottom: 2px solid #dee2e6; }
    tbody td { padding: 10px 8px; border-bottom: 1px solid #eee; vertical-align: top; }
    .text-end { text-align: right; }
    .text-center { text-align: center; }
    .text-muted { color: #888; }
    .text-success { color: #198754; }
    .fw-bold { font-weight: 600; }
    .small { font-size: 11px; }
    .strikethrough { text-decoration: line-through; color: #999; }

    .summary { margin-left: auto; width: 280px; }
    .summary-row { display: flex; justify-content: space-between; padding: 4px 0; }
    .summary-row.total { border-top: 2px solid #333; padding-top: 8px; margin-top: 4px; font-weight: 700; font-size: 15px; }
    .summary-row.discount { color: #198754; }

    .notes { background: #f8f9fa; padding: 12px 16px; border-radius: 6px; margin-top: 20px; }
    .notes h3 { font-size: 12px; text-transform: uppercase; color: #888; margin-bottom: 4px; }

    .footer { margin-top: 40px; padding-top: 15px; border-top: 1px solid #ddd; text-align: center; color: #999; font-size: 11px; }
  </style>
</head>
<body>
  <div class="header">
    <div>
      <h1><%= t('storefront.orders.pdf.order') %> #<%= @order.order_number %></h1>
      <div class="subtitle"><%= t('storefront.orders.pdf.placed_on') %>: <%= l(@order.placed_at, format: :long) %></div>
    </div>
    <div>
      <div class="org-name"><%= @order.organisation.name %></div>
    </div>
  </div>

  <div class="info-grid">
    <div class="info-block">
      <h3><%= t('storefront.orders.pdf.customer') %></h3>
      <p class="fw-bold"><%= @order.customer.company_name %></p>
      <p><%= @order.customer.contact_name %></p>
      <p class="text-muted"><%= @order.customer.email %></p>
      <% if @order.customer.contact_phone.present? %>
        <p class="text-muted"><%= @order.customer.contact_phone %></p>
      <% end %>
      <% if @order.customer.taxpayer_id.present? %>
        <p class="text-muted"><%= t('storefront.orders.pdf.tax_id') %>: <%= @order.customer.taxpayer_id %></p>
      <% end %>
    </div>

    <div class="info-block">
      <h3><%= t('storefront.orders.pdf.status') %></h3>
      <p>
        <% status_class = case @order.status
           when 'completed' then 'badge-success'
           when 'processed' then 'badge-info'
           when 'in_process' then 'badge-warning'
           else 'badge-secondary'
           end %>
        <span class="badge <%= status_class %>"><%= t("bo.common.statuses.#{@order.status}") %></span>
      </p>
      <p style="margin-top: 6px;">
        <% payment_class = case @order.payment_status
           when 'paid' then 'badge-success'
           when 'pending' then 'badge-warning'
           when 'failed' then 'badge-danger'
           else 'badge-info'
           end %>
        <span class="badge <%= payment_class %>"><%= t("bo.common.statuses.#{@order.payment_status}") %></span>
      </p>
    </div>

    <% if @order.delivery_method.present? %>
      <div class="info-block">
        <h3><%= t('storefront.orders.pdf.delivery') %></h3>
        <p><%= @order.pickup? ? t('bo.orders.form.pickup') : t('bo.orders.form.delivery') %></p>
        <% if @order.receive_on.present? %>
          <p class="text-muted"><%= l(@order.receive_on, format: :long) %></p>
        <% end %>
        <% if @order.delivery? && @order.shipping_address.present? %>
          <p class="text-muted" style="margin-top: 4px;">
            <%= @order.shipping_address.street_name %><br>
            <%= @order.shipping_address.postal_code %> <%= @order.shipping_address.city %>
          </p>
        <% end %>
      </div>
    <% end %>
  </div>

  <table>
    <thead>
      <tr>
        <th><%= t('storefront.orders.pdf.product') %></th>
        <th><%= t('storefront.orders.pdf.sku') %></th>
        <th class="text-center"><%= t('storefront.orders.pdf.qty') %></th>
        <th class="text-end"><%= t('storefront.orders.pdf.unit_price') %></th>
        <th class="text-center"><%= t('storefront.orders.pdf.discount') %></th>
        <th class="text-end"><%= t('storefront.orders.pdf.total') %></th>
      </tr>
    </thead>
    <tbody>
      <% @order.order_items.includes(:product, :product_variant).each do |item| %>
        <tr>
          <td>
            <div class="fw-bold"><%= item.product.name %></div>
            <% if item.product_variant.present? && item.product.variable? %>
              <div class="small text-muted"><%= item.product_variant.option_values_string %></div>
            <% end %>
          </td>
          <td class="text-muted small"><%= item.product_variant&.sku.presence || item.product.sku || '-' %></td>
          <td class="text-center"><%= item.quantity %></td>
          <td class="text-end">
            <% if item.discount_percentage.to_f > 0 %>
              <div class="small strikethrough"><%= humanized_money_with_symbol(item.price) %></div>
              <div class="text-success"><%= humanized_money_with_symbol(item.price - (item.price * item.discount_percentage)) %></div>
            <% else %>
              <%= humanized_money_with_symbol(item.price) %>
            <% end %>
          </td>
          <td class="text-center">
            <% if item.discount_percentage.to_f > 0 %>
              <span class="text-success">-<%= format_discount_percentage(item.discount_percentage) %></span>
            <% else %>
              -
            <% end %>
          </td>
          <td class="text-end fw-bold">
            <% if item.discount_percentage.to_f > 0 %>
              <div class="small strikethrough"><%= humanized_money_with_symbol(item.price * item.quantity) %></div>
              <div class="text-success"><%= humanized_money_with_symbol(item.total_price) %></div>
            <% else %>
              <%= humanized_money_with_symbol(item.total_price) %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="summary">
    <div class="summary-row">
      <span class="text-muted"><%= t('storefront.orders.pdf.subtotal') %></span>
      <span><%= humanized_money_with_symbol(@order.total_amount) %></span>
    </div>

    <% if @order.has_auto_discount_snapshot? %>
      <div class="summary-row discount">
        <span><%= t('storefront.orders.pdf.order_discount') %> (<%= @order.auto_discount_display %>)</span>
        <span>-<%= humanized_money_with_symbol(@order.auto_order_discount_amount) %></span>
      </div>
    <% end %>

    <% if @order.has_order_discount? %>
      <div class="summary-row discount">
        <span><%= t('storefront.orders.pdf.manual_discount') %> (<%= @order.order_discount_display %>)</span>
        <span>-<%= humanized_money_with_symbol(@order.order_discount_amount) %></span>
      </div>
    <% end %>

    <% if @order.promo_code_discount_amount_cents.present? && @order.promo_code_discount_amount_cents > 0 %>
      <div class="summary-row discount">
        <span><%= t('storefront.orders.pdf.promo_code') %><% if @order.promo_code.present? %> (<%= @order.promo_code.code %>)<% end %></span>
        <span>-<%= humanized_money_with_symbol(@order.promo_code_discount) %></span>
      </div>
    <% end %>

    <div class="summary-row">
      <span class="text-muted"><%= t('storefront.orders.pdf.tax') %> (<%= (@order.organisation.tax_rate * 100).round(1) %>%)</span>
      <span><%= humanized_money_with_symbol(@order.tax_amount || @order.calculated_tax) %></span>
    </div>

    <div class="summary-row">
      <span class="text-muted"><%= t('storefront.orders.pdf.shipping') %></span>
      <span><%= humanized_money_with_symbol(@order.shipping_amount || @order.calculated_shipping) %></span>
    </div>

    <div class="summary-row total">
      <span><%= t('storefront.orders.pdf.grand_total') %></span>
      <span><%= humanized_money_with_symbol(@order.grand_total) %></span>
    </div>
  </div>

  <% if @order.notes.present? %>
    <div class="notes">
      <h3><%= t('storefront.orders.pdf.notes') %></h3>
      <p><%= @order.notes %></p>
    </div>
  <% end %>

  <div class="footer">
    <%= @order.organisation.name %> &mdash; <%= t('storefront.orders.pdf.generated_on') %> <%= l(Date.today, format: :long) %>
  </div>
</body>
</html>
