<%# "Almost there" unlock nudge — one product/category close to a discount.
    Local: opportunity (CartDiscountNudges::Opportunity). %>
<% remaining = opportunity.condition_type == :amount ? opportunity.remaining.format : t('storefront.carts.show.nudge.units', count: opportunity.remaining) %>
<div class="rounded p-2 mb-3" style="background: var(--bs-success-bg-subtle, #d1e7dd);">
  <div class="d-flex justify-content-between align-items-center small mb-1" style="gap: .5rem;">
    <span class="text-truncate">
      <i class="fa-solid fa-bolt text-success me-1"></i><strong><%= opportunity.label %></strong>
      · <%= t('storefront.carts.show.nudge.remaining', remaining: remaining, discount: opportunity.discount_label) %>
    </span>
    <span class="badge bg-success text-nowrap"><%= t('storefront.carts.show.nudge.save', amount: opportunity.reward.format) %></span>
  </div>
  <div class="progress" style="height: 6px;">
    <div class="progress-bar bg-success" role="progressbar" style="width: <%= (opportunity.progress * 100).round %>%;"></div>
  </div>
</div>
