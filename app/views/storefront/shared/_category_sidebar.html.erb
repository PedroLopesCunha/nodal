<div class="card sidebar-card sidebar-sticky">
  <div class="card-body">
    <%# Search bar %>
    <div class="mb-3">
      <%= form_with url: products_path(org_slug: params[:org_slug]), method: :get, local: true do %>
        <%= hidden_field_tag 'category', params[:category] if params[:category].present? %>
        <% Array(params[:queries]).each do |q| %>
          <%= hidden_field_tag 'queries[]', q %>
        <% end %>
        <%= hidden_field_tag 'sort', params[:sort] if params[:sort].present? %>
        <div class="search-minimal">
          <%= text_field_tag 'queries[]', nil, class: "form-control", placeholder: t('storefront.products.index.search_placeholder') %>
          <i class="fa-solid fa-magnifying-glass search-minimal-icon"></i>
          <button type="submit" class="search-minimal-btn" aria-label="Search">
            <i class="fa-solid fa-arrow-right"></i>
          </button>
        </div>
      <% end %>
    </div>

    <h6 class="card-title mb-3"><%= t('storefront.products.index.categories') %></h6>
    <div class="category-sidebar" data-controller="storefront-category-tree">
      <ul class="list-unstyled mb-0">
        <li>
          <% all_params = { org_slug: params[:org_slug], queries: params[:queries] } %>
          <% all_params[:sort] = params[:sort] if params[:sort].present? %>
          <%= link_to products_path(**all_params),
              class: "category-link d-block py-1 #{'active fw-bold' if params[:category].blank?}" do %>
            <i class="fa-solid fa-grid-2 me-2"></i>
            <%= t('storefront.products.index.all_products') %>
          <% end %>
        </li>
        <% categories.each do |category| %>
          <%= render 'storefront/shared/category_tree_item', category: category, current_categories: local_assigns[:current_categories] %>
        <% end %>
      </ul>
    </div>
    <% if params[:category].present? || Array(params[:queries]).any? %>
      <div class="mt-3 pt-3 border-top">
        <%= link_to products_path(org_slug: params[:org_slug]), class: "btn btn-outline-secondary btn-sm w-100" do %>
          <i class="fa-solid fa-times me-2"></i><%= t('storefront.products.index.clear_filters') %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
