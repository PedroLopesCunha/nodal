<div class="mt-3 mb-3">
  <% if local_assigns[:back_path] %>
    <%= link_to back_path, class: "text-muted text-decoration-none small d-inline-flex align-items-center mb-2" do %>
      <i class="fa-solid fa-chevron-left me-1" style="font-size: 0.7rem;"></i> <%= local_assigns[:back_label] || t('storefront.common.back') %>
    <% end %>
  <% end %>

  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
    <div>
      <% if local_assigns[:title].present? %>
        <h1 class="h2 mb-0"><%= title %></h1>
      <% end %>
      <% if local_assigns[:subtitle] %>
        <p class="text-muted mb-0 mt-1"><%= subtitle %></p>
      <% end %>
    </div>
    <% if local_assigns[:actions] %>
      <div class="d-flex gap-2 flex-wrap">
        <%= actions %>
      </div>
    <% end %>
  </div>
</div>
