<div class="mt-4 mb-4">
  <% if local_assigns[:back_path] %>
    <%= link_to back_path, class: "btn btn-outline-secondary btn-sm mb-3" do %>
      <i class="fa-solid fa-arrow-left me-2"></i><%= local_assigns[:back_label] || t('storefront.common.back') %>
    <% end %>
  <% end %>

  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
    <div>
      <h1 class="h2 mb-0"><%= title %></h1>
      <% if local_assigns[:subtitle] %>
        <p class="text-muted mb-0 mt-1"><%= subtitle %></p>
      <% end %>
    </div>
    <% if local_assigns[:actions] %>
      <div class="d-flex gap-2 flex-wrap">
        <%= actions %>
      </div>
    <% end %>
  </div>
</div>
