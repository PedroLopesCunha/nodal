<footer class="storefront-footer border-top mt-auto">
  <div class="container py-4">
    <div class="d-flex align-items-center justify-content-center gap-3 flex-wrap">
      <% if current_organisation.instagram_url.present? %>
        <%= link_to current_organisation.instagram_url, target: "_blank", class: "text-muted fs-5", title: "Instagram" do %>
          <i class="fa-brands fa-instagram"></i>
        <% end %>
      <% end %>
      <% if current_organisation.facebook_url.present? %>
        <%= link_to current_organisation.facebook_url, target: "_blank", class: "text-muted fs-5", title: "Facebook" do %>
          <i class="fa-brands fa-facebook"></i>
        <% end %>
      <% end %>
      <% if current_organisation.linkedin_url.present? %>
        <%= link_to current_organisation.linkedin_url, target: "_blank", class: "text-muted fs-5", title: "LinkedIn" do %>
          <i class="fa-brands fa-linkedin"></i>
        <% end %>
      <% end %>
      <% if current_organisation.has_contact_info? %>
        <%= link_to contact_path(org_slug: params[:org_slug]), class: "btn btn-outline-secondary btn-sm" do %>
          <i class="fa-solid fa-address-card me-1"></i>
          <%= t('storefront.footer.contact_us') %>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="container py-2">
    <div class="d-flex justify-content-center gap-3">
      <%= link_to t("footer.legal.terms"), terms_path(org_slug: current_organisation.slug), class: "text-muted small text-decoration-none" %>
      <%= link_to t("footer.legal.privacy"), privacy_path(org_slug: current_organisation.slug), class: "text-muted small text-decoration-none" %>
    </div>
  </div>

  <%= render "storefront/shared/powered_by_nodal" %>
</footer>
