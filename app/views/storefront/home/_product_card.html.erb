<%= link_to product_path(org_slug: params[:org_slug], id: product), class: "text-decoration-none" do %>
  <div class="card h-100 product-card">
    <% discount_info = product_discounts[product.id] if product_discounts %>
    <div class="product-card-image">
      <%= render "storefront/shared/product_card_badges", discount_info: discount_info, show_promotion_badge: false %>
      <% if (display = product.display_photo) %>
        <%= image_tag display, alt: product.name %>
      <% else %>
        <i class="fa-solid fa-image placeholder-icon"></i>
      <% end %>
    </div>
    <div class="card-body">
      <% if product.primary_category&.name.present? %>
        <span class="product-card-category"><%= product.primary_category.name %></span>
      <% end %>
      <h6 class="product-card-title mb-0"><%= product.name %></h6>
    </div>
    <div class="card-footer">
      <div class="d-flex justify-content-between align-items-center">
        <% if show_prices? %>
          <%= render "storefront/shared/product_card_price", product: product, discount_info: discount_info %>
        <% end %>
        <span class="product-card-unit"><%= product.unit_description %></span>
      </div>
    </div>
  </div>
<% end %>
