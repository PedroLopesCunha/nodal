<%# Met / "unlock" hint for a line discount's condition (quantity or € value).
    Local: discount — a discount hash carrying :condition + :meets_condition. %>
<% condition = discount[:condition] %>
<% if condition %>
  <% where = if condition[:scope] == :summed
       condition[:target] == :category ? t('storefront.products.show.scope_category') : t('storefront.products.show.scope_summed_variants')
     else
       t('storefront.products.show.scope_per_variant')
     end %>
  <% if condition[:type] == :quantity && condition[:quantity].to_i > 1 %>
    <% if discount[:meets_condition] %>
      <small class="text-success d-block">
        <i class="fa-solid fa-check me-1"></i><%= t('storefront.products.show.min_quantity_met') %> <%= t('storefront.products.show.units_threshold', quantity: condition[:quantity]) %>
      </small>
    <% else %>
      <small class="text-warning d-block">
        <i class="fa-solid fa-info-circle me-1"></i><%= t('storefront.products.show.buy_to_unlock', quantity: condition[:quantity], where: where) %>
      </small>
    <% end %>
  <% elsif condition[:type] == :amount %>
    <% if discount[:meets_condition] %>
      <small class="text-success d-block">
        <i class="fa-solid fa-check me-1"></i><%= t('storefront.products.show.min_amount_met') %>
      </small>
    <% else %>
      <small class="text-warning d-block">
        <i class="fa-solid fa-info-circle me-1"></i><%= t('storefront.products.show.spend_to_unlock', amount: condition[:amount].format, where: where) %>
      </small>
    <% end %>
  <% end %>
<% end %>
