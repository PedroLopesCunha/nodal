<% if @available_attributes.present? %>
  <%= form_with url: products_path(org_slug: params[:org_slug]), method: :get,
                data: { controller: "attribute-filter" },
                class: "attribute-filters d-flex flex-wrap align-items-center gap-2" do %>
    <%# Preserve the other active filters so applying attributes keeps them %>
    <%= hidden_field_tag 'category', params[:category] if params[:category].present? %>
    <% Array(params[:queries]).reject(&:blank?).each do |q| %>
      <%= hidden_field_tag 'queries[]', q %>
    <% end %>
    <%= hidden_field_tag 'sort', params[:sort] if params[:sort].present? %>

    <% @available_attributes.each do |attribute| %>
      <% has_selected = attribute[:values].any? { |v| v[:selected] } %>
      <div class="dropdown" data-attribute-filter-target="dropdown">
        <button class="btn btn-sm <%= has_selected ? 'btn-primary' : 'btn-outline-secondary' %> dropdown-toggle"
                type="button"
                data-bs-toggle="dropdown"
                data-bs-auto-close="outside"
                aria-expanded="false">
          <%= attribute[:name] %>
        </button>
        <div class="dropdown-menu p-3 attribute-filter-dropdown">
          <% attribute[:values].each do |value| %>
            <label class="attribute-filter-option dropdown-item d-flex align-items-center gap-2 px-1 py-1 rounded">
              <input type="checkbox" class="attr-filter-check"
                     name="attrs[<%= attribute[:slug] %>][]"
                     value="<%= value[:slug] %>"
                     <%= 'checked' if value[:selected] %>>
              <% if value[:color_hex].present? %>
                <span class="attribute-color-swatch"
                      style="background-color: <%= value[:color_hex] %>;"
                      title="<%= value[:label] %>"></span>
              <% else %>
                <i class="fa-regular fa-square attr-icon-unchecked text-primary"></i>
                <i class="fa-solid fa-square-check attr-icon-checked text-primary"></i>
              <% end %>
              <span class="flex-grow-1"><%= value[:label] %></span>
              <small class="text-muted">(<%= value[:count] %>)</small>
            </label>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
<% end %>
