<div data-controller="scroll-restoration">
<div class="d-flex justify-content-between align-items-center mb-3 mt-2">
  <h1 class="mb-0 h2"><%= current_organisation.name %></h1>

  <%# Mobile filter button (visible only on mobile) %>
  <button class="btn btn-outline-primary d-lg-none"
          type="button"
          data-bs-toggle="offcanvas"
          data-bs-target="#categoryFilterOffcanvas"
          aria-controls="categoryFilterOffcanvas">
    <i class="fa-solid fa-filter me-2"></i><%= t('storefront.products.index.filters_button') %>
    <% attr_filter_count = params[:attrs].present? ? params[:attrs].values.sum { |v| Array(v).length } : 0 %>
    <% active_filter_count = (params[:category].present? ? 1 : 0) + Array(params[:queries]).length + attr_filter_count %>
    <% if active_filter_count > 0 %>
      <span class="badge bg-primary ms-1"><%= active_filter_count %></span>
    <% end %>
  </button>
</div>

<%# Breadcrumbs — always reserve space to prevent layout shift %>
<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb mb-0" style="min-height: 1.5rem;">
    <% if @breadcrumbs.present? %>
      <li class="breadcrumb-item">
        <%= link_to products_path(org_slug: params[:org_slug]) do %>
          <i class="fa-solid fa-home"></i>
        <% end %>
      </li>
      <% @breadcrumbs.each_with_index do |category, index| %>
        <% if index == @breadcrumbs.length - 1 %>
          <li class="breadcrumb-item active" aria-current="page"><%= category.name %></li>
        <% else %>
          <li class="breadcrumb-item">
            <%= link_to category.name, products_path(org_slug: params[:org_slug], category: category.id) %>
          </li>
        <% end %>
      <% end %>
    <% end %>
  </ol>
</nav>

<%# Applied filters breadbox %>
<%= render 'storefront/products/applied_filters', active_filters: @active_filters %>

<%# Mobile offcanvas sidebar %>
<div class="offcanvas offcanvas-start d-lg-none"
     tabindex="-1"
     id="categoryFilterOffcanvas"
     aria-labelledby="categoryFilterOffcanvasLabel">
  <div class="offcanvas-header border-bottom">
    <h5 class="offcanvas-title" id="categoryFilterOffcanvasLabel">
      <i class="fa-solid fa-filter me-2"></i><%= t('storefront.products.index.filters_title') %>
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div class="offcanvas-body">
    <%# Search %>
    <div class="mb-4">
      <h6 class="card-title mb-3"><%= t('storefront.products.index.search') %></h6>
      <%= form_with url: products_path(org_slug: params[:org_slug]), method: :get, local: true do %>
        <%= hidden_field_tag 'category', params[:category] if params[:category].present? %>
        <% Array(params[:queries]).each do |q| %>
          <%= hidden_field_tag 'queries[]', q %>
        <% end %>
        <%= hidden_field_tag 'sort', params[:sort] if params[:sort].present? %>
        <%= render 'storefront/products/attrs_hidden_fields' %>
        <div class="sidebar-search">
          <%= text_field_tag 'queries[]', nil, class: "form-control", placeholder: t('storefront.products.index.search_placeholder') %>
          <button type="submit" class="sidebar-search-btn" aria-label="Search">
            <i class="fa-solid fa-magnifying-glass"></i>
          </button>
        </div>
      <% end %>
    </div>

    <%# Categories %>
    <%= render 'storefront/shared/category_sidebar_content', categories: @categories, current_categories: @current_categories %>

    <%# Attribute filters (mobile) %>
    <% if @available_attributes.present? %>
      <div class="mt-4 pt-3 border-top">
        <h6 class="mb-3"><%= t('storefront.products.index.filters.filter_by') %></h6>
        <div class="accordion accordion-flush" id="mobileAttributeFilters">
          <% @available_attributes.each_with_index do |attribute, idx| %>
            <div class="accordion-item border-0">
              <h2 class="accordion-header">
                <button class="accordion-button collapsed px-0 py-2" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mobileAttr<%= idx %>"
                        aria-expanded="false">
                  <%= attribute[:name] %>
                  <% selected_count = attribute[:values].count { |v| v[:selected] } %>
                  <% if selected_count > 0 %>
                    <span class="badge bg-primary ms-2"><%= selected_count %></span>
                  <% end %>
                </button>
              </h2>
              <div id="mobileAttr<%= idx %>" class="accordion-collapse collapse">
                <div class="accordion-body px-0 pt-1 pb-2">
                  <% attribute[:values].each do |value| %>
                    <%
                      if value[:selected]
                        new_slugs = (@current_attrs[attribute[:slug]] || []) - [value[:slug]]
                        toggle_attrs = @current_attrs.except(attribute[:slug])
                        toggle_attrs[attribute[:slug]] = new_slugs if new_slugs.any?
                      else
                        new_slugs = (@current_attrs[attribute[:slug]] || []) + [value[:slug]]
                        toggle_attrs = @current_attrs.merge(attribute[:slug] => new_slugs)
                      end
                      filter_params = {
                        org_slug: params[:org_slug],
                        category: params[:category],
                        queries: params[:queries],
                        sort: params[:sort],
                        attrs: toggle_attrs.presence
                      }.compact
                    %>
                    <%= link_to products_path(**filter_params), class: "d-flex align-items-center gap-2 py-1 text-decoration-none text-body" do %>
                      <% if value[:color_hex].present? %>
                        <span class="attribute-color-swatch <%= 'selected' if value[:selected] %>"
                              style="background-color: <%= value[:color_hex] %>;"></span>
                      <% else %>
                        <i class="fa-<%= value[:selected] ? 'solid' : 'regular' %> fa-square<%= '-check' if value[:selected] %> text-primary"></i>
                      <% end %>
                      <span class="flex-grow-1"><%= value[:label] %></span>
                      <small class="text-muted">(<%= value[:count] %>)</small>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Clear filters button %>
    <% if params[:category].present? || Array(params[:queries]).any? || params[:attrs].present? %>
      <div class="mt-4 pt-3 border-top">
        <%= link_to products_path(org_slug: params[:org_slug]), class: "btn btn-outline-secondary w-100" do %>
          <i class="fa-solid fa-times me-2"></i><%= t('storefront.products.index.clear_filters') %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<%# Search bar / clear filters + product count / sort %>
<% has_filters = params[:category].present? || Array(params[:queries]).any? %>
<div class="row mb-2 align-items-center">
  <%# Left: search bar + clear filters (aligned with sidebar) %>
  <div class="col-lg-3 d-none d-lg-flex align-items-center gap-2">
    <%= form_with url: products_path(org_slug: params[:org_slug]), method: :get, local: true, class: "flex-grow-1" do %>
      <%= hidden_field_tag 'category', params[:category] if params[:category].present? %>
      <% Array(params[:queries]).each do |q| %>
        <%= hidden_field_tag 'queries[]', q %>
      <% end %>
      <%= hidden_field_tag 'sort', params[:sort] if params[:sort].present? %>
      <%= render 'storefront/products/attrs_hidden_fields' %>
      <div class="search-minimal">
        <%= text_field_tag 'queries[]', nil, class: "form-control", placeholder: t('storefront.products.index.search_placeholder') %>
        <i class="fa-solid fa-magnifying-glass search-minimal-icon"></i>
        <button type="submit" class="search-minimal-btn" aria-label="Search">
          <i class="fa-solid fa-arrow-right"></i>
        </button>
      </div>
    <% end %>
  </div>

  <%# Right: attribute filters + product count + sort (all in one row) %>
  <div class="col-lg-9">
    <% if @products.any? || @current_attrs.present? %>
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <%# Left: attribute filters %>
        <div class="d-none d-lg-flex align-items-center flex-wrap gap-2">
          <%= render 'storefront/products/attribute_filters' %>
        </div>

        <%# Right: sort %>
        <div class="d-flex align-items-center">
          <% sort_base_params = { org_slug: params[:org_slug], category: params[:category], queries: params[:queries], attrs: @current_attrs.presence } %>
          <div class="dropdown">
            <button class="btn btn-sm btn-outline-secondary border-0 text-muted text-uppercase dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 0.8rem; letter-spacing: 0.03em;">
              <%= t('storefront.products.index.sort.label') %>
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
              <% %w[name_asc name_desc price_asc price_desc newest].each do |sort_key| %>
                <li>
                  <%= link_to t("storefront.products.index.sort.#{sort_key}"),
                      products_path(**sort_base_params, sort: sort_key),
                      class: "dropdown-item #{'active' if @current_sort == sort_key}" %>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="row">
  <%# Desktop sidebar with filters (hidden on mobile) %>
  <div class="col-lg-3 mb-4 d-none d-lg-block">
    <%= render 'storefront/shared/category_sidebar', categories: @categories, current_categories: @current_categories %>
  </div>

  <%# Product grid %>
  <div class="col-lg-9">
    <% if @products.any? %>
      <div class="row row-cols-2 row-cols-md-2 row-cols-xl-3 product-grid">
        <% @products.each do |product| %>
          <div class="col">
            <%= link_to product_path(org_slug: params[:org_slug], id: product, category: params[:category], queries: params[:queries], attrs: @current_attrs.presence, page: params[:page]), class: "text-decoration-none" do %>
              <div class="card h-100 product-card">
                <% discount_info = @product_discounts[product.id] %>
                <div class="product-card-image">
                  <% if (display = product.display_photo) %>
                    <%= image_tag display, alt: product.name %>
                  <% else %>
                    <i class="fa-solid fa-image placeholder-icon"></i>
                  <% end %>
                </div>
                <div class="card-body">
                  <% if product.primary_category&.name.present? %>
                    <span class="product-card-category"><%= product.primary_category.name %></span>
                  <% end %>
                  <h5 class="product-card-title"><%= product.name %></h5>
                </div>
                <div class="card-footer">
                  <div class="d-flex justify-content-between align-items-center">
                    <% if product.price_on_request? %>
                      <span class="product-card-price"><%= t('storefront.products.index.price_on_request') %></span>
                    <% elsif discount_info && discount_info[:has_discount] %>
                      <div>
                        <span class="product-card-price-original">
                          <%= humanized_money_with_symbol(discount_info[:base_price]) %>
                        </span>
                        <span class="product-card-price-discounted">
                          <%= humanized_money_with_symbol(discount_info[:final_price]) %>
                        </span>
                        <span class="badge bg-success product-card-discount-badge">
                          <% pct = discount_info[:effective_discount][:percentage].to_f %>
                          -<%= pct.finite? ? (pct * 100).round(0) : 0 %>%
                        </span>
                        <% if discount_info[:all_discounts].any? { |d| d[:type] == :product || d[:type] == :category } %>
                          <span class="badge bg-danger product-card-sale-badge ms-1"><%= t('storefront.products.index.sale_badge') %></span>
                        <% end %>
                      </div>
                    <% elsif product.variable? %>
                      <span class="product-card-price"><%= product.display_price %></span>
                    <% else %>
                      <span class="product-card-price"><%= humanized_money_with_symbol(product.price) %></span>
                    <% end %>
                    <span class="product-card-unit"><%= product.unit_description %></span>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <%# Pagination controls %>
      <div class="mt-4 d-flex flex-column align-items-center">
        <small class="text-muted mb-2">
          <%= t('storefront.products.index.showing_products',
                from: @pagy.from,
                to: @pagy.to,
                count: @pagy.count) %>
        </small>
        <% if @pagy.pages > 1 %>
          <%== pagy_bootstrap_nav(@pagy) %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="fa-solid fa-box-open fa-4x text-muted mb-3"></i>
        <h4><%= t('storefront.products.index.no_products') %></h4>
        <p class="text-muted">
          <% if Array(params[:queries]).any? || params[:category].present? %>
            <%= t('storefront.products.index.no_products_hint') %>
          <% else %>
            <%= t('storefront.products.index.empty_catalog') %>
          <% end %>
        </p>
      </div>
    <% end %>
  </div>
</div>

</div>
