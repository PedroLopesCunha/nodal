<% sort_base_params = { org_slug: params[:org_slug], category: params[:category], queries: params[:queries], attrs: @current_attrs.presence } %>
<% attr_filter_count = params[:attrs].present? ? params[:attrs].values.sum { |v| Array(v).length } : 0 %>
<% active_filter_count = Array(params[:queries]).length + attr_filter_count %>

<div data-controller="scroll-restoration">
<div class="mb-2 mt-2"></div>

<%# Breadcrumbs — desktop only (chips replace this on mobile) %>
<nav aria-label="breadcrumb" class="mb-3 d-none d-lg-block">
  <ol class="breadcrumb mb-0" style="min-height: 1.5rem;">
    <% if @breadcrumbs.present? %>
      <li class="breadcrumb-item">
        <%= link_to products_path(org_slug: params[:org_slug]) do %>
          <i class="fa-solid fa-home"></i>
        <% end %>
      </li>
      <% @breadcrumbs.each_with_index do |category, index| %>
        <% if index == @breadcrumbs.length - 1 %>
          <li class="breadcrumb-item active" aria-current="page"><%= category.name %></li>
        <% else %>
          <li class="breadcrumb-item">
            <%= link_to category.name, products_path(org_slug: params[:org_slug], category: category.id) %>
          </li>
        <% end %>
      <% end %>
    <% end %>
  </ol>
</nav>

<%# Mobile category chips (visible only < lg) %>
<%
  # Determine which categories to show as chips:
  # - If inside a category with siblings, show parent's children + back chip
  # - Otherwise show top-level categories
  if @current_category && @current_category.parent
    chip_categories = (@category_children[@current_category.parent_id] || [])
    chip_back_target = @current_category.parent
  elsif @current_category && (@category_children[@current_category.id] || []).any?
    chip_categories = @category_children[@current_category.id] || []
    chip_back_target = nil
  else
    chip_categories = @categories
    chip_back_target = nil
  end
%>
<div class="mobile-category-chips d-lg-none" data-controller="horizontal-scroll">
  <div class="mobile-category-chips-track" data-horizontal-scroll-target="container">
    <% if chip_back_target %>
      <% back_params = { org_slug: params[:org_slug], category: chip_back_target.id } %>
      <% back_params[:sort] = params[:sort] if params[:sort].present? %>
      <%= link_to products_path(**back_params), class: "mobile-category-chip back-chip" do %>
        <i class="fa-solid fa-chevron-left me-1"></i> <%= chip_back_target.name %>
      <% end %>
    <% end %>

    <% unless chip_back_target %>
      <% all_params = { org_slug: params[:org_slug], queries: params[:queries] } %>
      <% all_params[:sort] = params[:sort] if params[:sort].present? %>
      <%= link_to products_path(**all_params),
          class: "mobile-category-chip #{'active' if params[:category].blank?}" do %>
        <%= t('storefront.products.index.all_products') %>
      <% end %>
    <% end %>

    <% chip_categories.each do |category| %>
      <% cat_params = { org_slug: params[:org_slug], category: category.id, queries: params[:queries] } %>
      <% cat_params[:sort] = params[:sort] if params[:sort].present? %>
      <%= link_to products_path(**cat_params),
          class: "mobile-category-chip #{'active' if @current_category&.id == category.id}" do %>
        <%= category.name %>
      <% end %>
    <% end %>
  </div>
</div>

<%# Applied filters breadbox %>
<%= render 'storefront/products/applied_filters', active_filters: @active_filters %>

<%# Mobile sticky toolbar (visible only < lg) %>
<div class="mobile-sticky-toolbar d-lg-none" data-controller="mobile-search-toggle">
  <div class="d-flex justify-content-between align-items-center">
    <small class="text-muted">
      <% if @products.respond_to?(:any?) && @products.any? %>
        <%= @pagy.count %> <%= t('storefront.products.index.products_count', count: @pagy.count) %>
      <% end %>
    </small>
    <div class="d-flex gap-1 align-items-center">
      <%# Search toggle %>
      <button class="btn btn-sm btn-outline-secondary border-0 text-muted" type="button"
              data-action="mobile-search-toggle#toggle">
        <i class="fa-solid fa-magnifying-glass"></i>
      </button>
      <%# Sort %>
      <div class="dropdown">
        <button class="btn btn-sm btn-outline-secondary border-0 text-muted" type="button" data-bs-toggle="dropdown" aria-expanded="false">
          <i class="fa-solid fa-arrow-down-short-wide"></i>
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
          <% %w[name_asc name_desc price_asc price_desc newest].each do |sort_key| %>
            <li>
              <%= link_to t("storefront.products.index.sort.#{sort_key}"),
                  products_path(**sort_base_params, sort: sort_key),
                  class: "dropdown-item #{'active' if @current_sort == sort_key}" %>
            </li>
          <% end %>
        </ul>
      </div>
      <%# Filter button — only when there are attribute filters to show %>
      <% if @available_attributes.present? %>
        <button class="btn btn-sm btn-outline-secondary border-0 text-muted position-relative"
                type="button"
                data-bs-toggle="offcanvas"
                data-bs-target="#mobileFilterSheet"
                aria-controls="mobileFilterSheet">
          <i class="fa-solid fa-sliders"></i>
          <% if active_filter_count > 0 %>
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary" style="font-size: 0.55rem;"><%= active_filter_count %></span>
          <% end %>
        </button>
      <% end %>
    </div>
  </div>
  <%# Expandable search bar %>
  <div class="mobile-toolbar-search collapsed" data-mobile-search-toggle-target="searchBar">
    <%= form_with url: products_path(org_slug: params[:org_slug]), method: :get, local: true, class: "mt-2" do %>
      <%= hidden_field_tag 'category', params[:category] if params[:category].present? %>
      <%= hidden_field_tag 'sort', params[:sort] if params[:sort].present? %>
      <%= render 'storefront/products/attrs_hidden_fields' %>
      <div class="input-group input-group-sm autocomplete-wrapper" data-controller="autocomplete-search" data-autocomplete-search-url-value="<%= autocomplete_products_path(org_slug: params[:org_slug]) %>">
        <%= text_field_tag 'queries[]', nil, class: "form-control", placeholder: t('storefront.products.index.search_placeholder'), data: { mobile_search_toggle_target: "input", autocomplete_search_target: "input", action: "input->autocomplete-search#search keydown->autocomplete-search#navigate" }, autocomplete: "off" %>
        <button type="submit" class="btn btn-outline-secondary" aria-label="Search">
          <i class="fa-solid fa-magnifying-glass"></i>
        </button>
        <div class="autocomplete-results" data-autocomplete-search-target="results"></div>
      </div>
    <% end %>
  </div>
</div>

<%# Mobile filter bottom sheet (refinement only — no categories) %>
<div class="offcanvas offcanvas-bottom d-lg-none mobile-filter-sheet"
     tabindex="-1"
     id="mobileFilterSheet"
     aria-labelledby="mobileFilterSheetLabel">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title" id="mobileFilterSheetLabel">
      <i class="fa-solid fa-sliders me-2"></i><%= t('storefront.products.index.filters_title') %>
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div class="offcanvas-body">
    <%# Attribute filters %>
    <% if @available_attributes.present? %>
      <div class="mb-4">
        <h6 class="filter-section-title"><%= t('storefront.products.index.filters.filter_by') %></h6>
        <div class="accordion accordion-flush" id="mobileAttributeFilters">
          <% @available_attributes.each_with_index do |attribute, idx| %>
            <div class="accordion-item border-0">
              <h2 class="accordion-header">
                <button class="accordion-button collapsed px-0 py-2" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mobileAttr<%= idx %>"
                        aria-expanded="false">
                  <%= attribute[:name] %>
                  <% selected_count = attribute[:values].count { |v| v[:selected] } %>
                  <% if selected_count > 0 %>
                    <span class="badge bg-primary ms-2"><%= selected_count %></span>
                  <% end %>
                </button>
              </h2>
              <div id="mobileAttr<%= idx %>" class="accordion-collapse collapse">
                <div class="accordion-body px-0 pt-1 pb-2">
                  <% attribute[:values].each do |value| %>
                    <%
                      if value[:selected]
                        new_slugs = (@current_attrs[attribute[:slug]] || []) - [value[:slug]]
                        toggle_attrs = @current_attrs.except(attribute[:slug])
                        toggle_attrs[attribute[:slug]] = new_slugs if new_slugs.any?
                      else
                        new_slugs = (@current_attrs[attribute[:slug]] || []) + [value[:slug]]
                        toggle_attrs = @current_attrs.merge(attribute[:slug] => new_slugs)
                      end
                      filter_params = {
                        org_slug: params[:org_slug],
                        category: params[:category],
                        queries: params[:queries],
                        sort: params[:sort],
                        attrs: toggle_attrs.presence
                      }.compact
                    %>
                    <%= link_to products_path(**filter_params), class: "d-flex align-items-center gap-2 py-2 text-decoration-none text-body" do %>
                      <% if value[:color_hex].present? %>
                        <span class="attribute-color-swatch <%= 'selected' if value[:selected] %>"
                              style="background-color: <%= value[:color_hex] %>;"></span>
                      <% else %>
                        <i class="fa-<%= value[:selected] ? 'solid' : 'regular' %> fa-square<%= '-check' if value[:selected] %> text-primary"></i>
                      <% end %>
                      <span class="flex-grow-1"><%= value[:label] %></span>
                      <small class="text-muted">(<%= value[:count] %>)</small>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Clear all filters %>
    <% if params[:category].present? || Array(params[:queries]).any? || params[:attrs].present? %>
      <div class="pt-3 border-top">
        <%= link_to products_path(org_slug: params[:org_slug]), class: "btn btn-outline-secondary w-100" do %>
          <i class="fa-solid fa-times me-2"></i><%= t('storefront.products.index.clear_filters') %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<%# Search bar / clear filters + product count / sort (desktop) %>
<div class="row mb-2 align-items-center">
  <%# Left: search bar (aligned with sidebar, desktop only) %>
  <div class="col-lg-3 d-none d-lg-flex align-items-center gap-2">
    <%= form_with url: products_path(org_slug: params[:org_slug]), method: :get, local: true, class: "flex-grow-1" do %>
      <%= hidden_field_tag 'category', params[:category] if params[:category].present? %>
      <% Array(params[:queries]).each do |q| %>
        <%= hidden_field_tag 'queries[]', q %>
      <% end %>
      <%= hidden_field_tag 'sort', params[:sort] if params[:sort].present? %>
      <%= render 'storefront/products/attrs_hidden_fields' %>
      <div class="search-minimal autocomplete-wrapper" data-controller="autocomplete-search" data-autocomplete-search-url-value="<%= autocomplete_products_path(org_slug: params[:org_slug]) %>">
        <%= text_field_tag 'queries[]', nil, class: "form-control", placeholder: t('storefront.products.index.search_placeholder'), data: { autocomplete_search_target: "input", action: "input->autocomplete-search#search keydown->autocomplete-search#navigate" }, autocomplete: "off" %>
        <i class="fa-solid fa-magnifying-glass search-minimal-icon"></i>
        <button type="submit" class="search-minimal-btn" aria-label="Search">
          <i class="fa-solid fa-arrow-right"></i>
        </button>
        <div class="autocomplete-results" data-autocomplete-search-target="results"></div>
      </div>
    <% end %>
  </div>

  <%# Right: attribute filters + sort (desktop) %>
  <div class="col-lg-9">
    <% if @products.any? || @current_attrs.present? %>
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div class="d-none d-lg-flex align-items-center flex-wrap gap-2">
          <%= render 'storefront/products/attribute_filters' %>
        </div>
        <div class="d-none d-lg-flex align-items-center">
          <div class="dropdown">
            <button class="btn btn-sm btn-outline-secondary border-0 text-muted text-uppercase dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 0.8rem; letter-spacing: 0.03em;">
              <%= t('storefront.products.index.sort.label') %>
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
              <% %w[name_asc name_desc price_asc price_desc newest].each do |sort_key| %>
                <li>
                  <%= link_to t("storefront.products.index.sort.#{sort_key}"),
                      products_path(**sort_base_params, sort: sort_key),
                      class: "dropdown-item #{'active' if @current_sort == sort_key}" %>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="row">
  <%# Desktop sidebar with filters (hidden on mobile) %>
  <div class="col-lg-3 mb-4 d-none d-lg-block">
    <%= render 'storefront/shared/category_sidebar', categories: @categories, current_categories: @current_categories %>
  </div>

  <%# Product grid %>
  <div class="col-lg-9">
    <% if @products.any? %>
      <div class="row row-cols-2 row-cols-md-2 row-cols-xl-3 product-grid">
        <% @products.each do |product| %>
          <div class="col">
            <%= link_to product_path(org_slug: params[:org_slug], id: product, category: params[:category], queries: params[:queries], attrs: @current_attrs.presence, page: params[:page]), class: "text-decoration-none" do %>
              <div class="card h-100 product-card">
                <% discount_info = @product_discounts[product.id] %>
                <div class="product-card-image">
                  <% if (display = product.display_photo) %>
                    <%= image_tag display, alt: product.name %>
                  <% else %>
                    <i class="fa-solid fa-image placeholder-icon"></i>
                  <% end %>
                </div>
                <div class="card-body">
                  <% if product.primary_category&.name.present? %>
                    <span class="product-card-category"><%= product.primary_category.name %></span>
                  <% end %>
                  <h5 class="product-card-title"><%= product.name %></h5>
                </div>
                <div class="card-footer">
                  <div class="d-flex justify-content-between align-items-center">
                    <% if product.price_on_request? %>
                      <span class="product-card-price"><%= t('storefront.products.index.price_on_request') %></span>
                    <% elsif discount_info && discount_info[:has_discount] %>
                      <div>
                        <span class="product-card-price-original">
                          <%= humanized_money_with_symbol(discount_info[:base_price]) %>
                        </span>
                        <span class="product-card-price-discounted">
                          <%= humanized_money_with_symbol(discount_info[:final_price]) %>
                        </span>
                        <span class="badge bg-success product-card-discount-badge">
                          <% pct = discount_info[:effective_discount][:percentage].to_f %>
                          -<%= pct.finite? ? (pct * 100).round(0) : 0 %>%
                        </span>
                        <% if discount_info[:all_discounts].any? { |d| d[:type] == :product || d[:type] == :category } %>
                          <span class="badge bg-danger product-card-sale-badge ms-1"><%= t('storefront.products.index.sale_badge') %></span>
                        <% end %>
                      </div>
                    <% elsif product.variable? %>
                      <span class="product-card-price"><%= product.display_price %></span>
                    <% else %>
                      <span class="product-card-price"><%= humanized_money_with_symbol(product.price) %></span>
                    <% end %>
                    <span class="product-card-unit"><%= product.unit_description %></span>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <%# Pagination controls %>
      <div class="mt-4 d-flex flex-column align-items-center">
        <small class="text-muted mb-2">
          <%= t('storefront.products.index.showing_products',
                from: @pagy.from,
                to: @pagy.to,
                count: @pagy.count) %>
        </small>
        <% if @pagy.pages > 1 %>
          <%== pagy_bootstrap_nav(@pagy) %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="fa-solid fa-box-open fa-4x text-muted mb-3"></i>
        <h4><%= t('storefront.products.index.no_products') %></h4>
        <p class="text-muted">
          <% if Array(params[:queries]).any? || params[:category].present? %>
            <%= t('storefront.products.index.no_products_hint') %>
          <% else %>
            <%= t('storefront.products.index.empty_catalog') %>
          <% end %>
        </p>
      </div>
    <% end %>
  </div>
</div>

</div>
